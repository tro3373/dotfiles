#!/usr/bin/env bash

## Usage: gtasks_to_tasks [-c|--complete] [list_id] [task_id|all|id1,id2,...]
##
## Google Tasks からタスクを選択し、Markdown 形式で標準出力に出力する。
##
##   Options:
##     -c, --complete   選択した親タスクを完了扱いにする (gog_complete_enabled=1)
##     -h, --help       このヘルプを表示
##
##   Arguments:
##     list_id          タスクリストID (省略時 fzf で選択)
##     task_id          タスクID (省略時 fzf で複数選択)
##                      "all" で全親タスク、 "id1,id2" でカンマ区切り複数指定
##
##   Flow:
##     1. list_id を引数 or fzf で決定
##     2. task_ids を引数 (all/カンマ区切り/単一) or fzf で決定
##     3. 選択タスクを Markdown 形式で stdout に出力
##     4. gog_complete_enabled=1 のとき、選択した親タスクを完了扱いにする
readonly depends=(gog jq git base64)
gog_complete_enabled=0
gog_use_client_id="${GOG_USE_CLIENT_ID:-default}"

has() { command -v "${1}" >&/dev/null; }
hass() {
  local arg
  for arg in "$@"; do has "$arg" || error "==> No $arg command exist."; done
}
_ink() { if has ink; then ink "$@"; else cat - 1>&2; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
error() { _log red "$*" && exit 1; }
usage() { grep '^##' "$0" | sed -E 's/^## ?//'; }

emit_task_block() {
  local task_json="${1:-}"
  local checkbox_indent="${2:-}"
  local notes_indent="${3:-}"

  if [[ -z ${task_json} ]]; then
    error "==> Error: emit_task_block: task_json required"
  fi

  local title notes links_json
  title=$(printf '%s' "${task_json}" | jq -r '.title // ""') || return 1
  notes=$(printf '%s' "${task_json}" | jq -r 'if .notes == null then "" else .notes end') || return 1
  links_json=$(printf '%s' "${task_json}" | jq -c '.links // []') || return 1

  # タイトル内 CR/改行は Markdown 構造を壊すので除去 (CR は削除、LF は空白化)
  title=${title//$'\r'/}
  title=${title//$'\n'/ }

  printf -- '%s- [ ] %s\n' "${checkbox_indent}" "${title}"

  if [[ -n ${notes} ]]; then
    local line
    while IFS= read -r line; do
      line=${line%$'\r'}
      [[ ${line} =~ ^[[:space:]]*$ ]] && continue
      # 行頭の bullet マーカー ("- ", "* ", "+ ") を剥がす（先頭空白も許容）
      if [[ ${line} =~ ^[[:space:]]*[-*+][[:space:]]+(.*)$ ]]; then
        line="${BASH_REMATCH[1]}"
      fi
      printf -- '%s- %s\n' "${notes_indent}" "${line}"
    done <<<"${notes}"
  fi

  # links フィールド (email / generic URL など) を bullet 化
  [[ ${links_json} == "[]" || ${links_json} == "null" ]] && return 0
  local link_desc link_url
  while IFS=$'\t' read -r link_desc link_url; do
    [[ -z ${link_url} ]] && continue
    if [[ -z ${link_desc} || ${link_desc} == "${link_url}" ]]; then
      printf -- '%s- %s\n' "${notes_indent}" "${link_url}"
      continue
    fi
    printf -- '%s- [%s](%s)\n' "${notes_indent}" "${link_desc}" "${link_url}"
  done < <(printf '%s' "${links_json}" | jq -r '.[] | "\(.description // "")\t\(.link // "")"')
}

format_task() {
  local task_json="${1:-}"
  local subtasks_json="${2:-"[]"}"

  if [[ -z ${task_json} ]]; then
    error "==> Error: format_task: task_json required"
  fi

  emit_task_block "${task_json}" "" "  " || return 1

  local sub_json
  while IFS= read -r sub_json; do
    [[ -z ${sub_json} ]] && continue
    emit_task_block "${sub_json}" "  " "    " || return 1
  done < <(printf '%s' "${subtasks_json}" | jq -c '.[]')
}

_gog() {
  local args=()
  if [[ -n $gog_use_client_id ]]; then
    args+=("--client=$gog_use_client_id")
  fi
  gog "${args[@]}" "$@"
}

# 親タスク全件をバンドル (id\ttitle\t<base64(parent+subtasks JSON)>) のTSV行に展開する jq フィルタ。
# 完了済み (status=="completed") は親・子ともに除外する。
# 3カラム目を base64 化することで notes 等に含まれる改行/タブが @tsv のエスケープで潰れるのを防ぐ。
# fzf に流して --with-nth=2..2 で title だけ表示し、選択行から bundle を取り出して使う。
# shellcheck disable=SC2016 # jq の変数なのでシェル展開させない
readonly bundle_jq_filter='
  [(. // [])[] | select((.status // "") != "completed")] as $all |
  [$all[] | select((.parent // "") == "")] | sort_by(.position) | .[] as $p |
  ([$all[] | select(.parent == $p.id)] | sort_by(.position)) as $subs |
  [$p.id, $p.title, ({parent: $p, subtasks: $subs} | @json | @base64)] | @tsv
'

# 引数 $ids (JSON配列) で指定された親タスクのみ bundle TSV に展開する jq フィルタ
# 完了済み (status=="completed") は親・子ともに除外する。
# shellcheck disable=SC2016 # jq の変数なのでシェル展開させない
readonly bundle_by_ids_jq_filter='
  [(. // [])[] | select((.status // "") != "completed")] as $all |
  $ids[] as $id |
  ([$all[] | select(.id == $id)] | first) | select(. != null) as $p |
  ([$all[] | select(.parent == $id)] | sort_by(.position)) as $subs |
  [$p.id, $p.title, ({parent: $p, subtasks: $subs} | @json | @base64)] | @tsv
'

select_list_id_via_fzf() {
  _gog tasks lists list --json --results-only --all |
    jq -r '(. // [])[] | "\(.id)\t\(.title)"' |
    { fzf --no-multi --prompt='List> ' --with-nth=2.. --delimiter=$'\t' || true; } |
    cut -f1
}

resolve_list_id() {
  local arg="${1:-}"
  if [[ -n ${arg} ]]; then
    printf '%s\n' "${arg}"
    return
  fi
  info "==> 📋 Fetching Google Tasks lists..."
  select_list_id_via_fzf
}

# task_arg を解釈し (id\ttitle\tbundle_json) のTSVストリームを stdout に出力する。
#   ""              → fzf で複数選択
#   "all"           → 全親タスク
#   "id1,id2,..."   → カンマ区切り指定IDのみ
#   "<single_id>"   → 単一ID
stream_target_bundles() {
  local list_id="$1"
  local task_arg="${2:-}"

  if [[ ${task_arg} == "all" ]]; then
    _gog tasks list "${list_id}" --json --results-only --all |
      jq -r "${bundle_jq_filter}"
    return
  fi

  if [[ -n ${task_arg} ]]; then
    local ids_json
    ids_json=$(
      printf '%s' "${task_arg}" |
        tr ',' '\n' |
        jq -R . |
        jq -cs 'map(select(length > 0))'
    )
    _gog tasks list "${list_id}" --json --results-only --all |
      jq -r --argjson ids "${ids_json}" "${bundle_by_ids_jq_filter}"
    return
  fi

  _gog tasks list "${list_id}" --json --results-only --all |
    jq -r "${bundle_jq_filter}" |
    {
      fzf --multi \
        --prompt='Tasks> ' \
        --with-nth=2..2 \
        --bind 'ctrl-l:toggle-all,ctrl-g:toggle-preview,ctrl-y:execute-silent(echo {} |clip)+abort' \
        --delimiter=$'\t' || true
    }
}

emit_from_bundle() {
  local bundle_b64="${1:-}"
  if [[ -z ${bundle_b64} ]]; then
    error "==> Error: emit_from_bundle: bundle_b64 required"
  fi
  local bundle_json
  bundle_json=$(printf '%s' "${bundle_b64}" | base64 -d) || return 1
  local task_json subtasks_json
  task_json=$(printf '%s' "${bundle_json}" | jq -c '.parent') || return 1
  subtasks_json=$(printf '%s' "${bundle_json}" | jq -c '.subtasks') || return 1
  format_task "${task_json}" "${subtasks_json}"
}

complete_tasks() {
  local list_id="${1:-}"
  shift || true
  if [[ -z ${list_id} || $# -eq 0 ]]; then
    error "==> Error: complete_tasks: list_id and task_ids required"
  fi
  local task_id
  for task_id in "$@"; do
    [[ -z ${task_id} ]] && continue
    info "==> Completing task: ${task_id}"
    _gog tasks "done" "${list_id}" "${task_id}" 1>&2
  done
}

run() {
  local arg_list_id="${1:-}"
  local arg_task_id="${2:-}"
  if [[ -z $arg_list_id || -z $arg_task_id ]]; then
    hass fzf
  fi

  local list_id
  list_id=$(resolve_list_id "${arg_list_id}")
  if [[ -z ${list_id} ]]; then
    error "==> No list selected. Aborted."
  fi

  info "==> 📋 Fetching tasks from list: ${list_id}"

  local count=0
  local selected_ids=()
  local id title bundle_json
  while IFS=$'\t' read -r id title bundle_json; do
    [[ -z ${id} ]] && continue
    emit_from_bundle "${bundle_json}"
    count=$((count + 1))
    selected_ids+=("${id}")
  done < <(stream_target_bundles "${list_id}" "${arg_task_id}")

  if ((count == 0)); then
    error "==> No task selected. Aborted."
  fi

  info "==> ✅ Output ${count} task(s)"

  if [[ ${gog_complete_enabled} -ne 1 ]]; then
    info "==> 完了処理スキップ"
    return
  fi
  complete_tasks "${list_id}" "${selected_ids[@]}"
}

is_gog_valid() {
  res=$(gog auth list --check --json | jq -r --arg client "$gog_use_client_id" '.accounts[] | select(.client == $client) | .valid' | head -1)
  [[ ${res} == "true" ]]
}

main() {
  set -euo pipefail

  local positional=()
  while [[ $# -gt 0 ]]; do
    case "${1}" in
      -h | --help)
        usage
        return 0
        ;;
      -c | --complete)
        gog_complete_enabled=1
        shift
        ;;
      --)
        shift
        positional+=("$@")
        break
        ;;
      -*)
        error "==> Error: unknown option: ${1}"
        ;;
      *)
        positional+=("${1}")
        shift
        ;;
    esac
  done

  hass "${depends[@]}"
  is_gog_valid || error "==> Error: gog auth status invalid for client '$gog_use_client_id'"
  run "${positional[@]+"${positional[@]}"}"
}

# 直接実行時のみ main を起動（テストで source するときは main を起動しない）
if [[ ${BASH_SOURCE[0]} == "${0}" ]]; then
  main "$@"
fi
