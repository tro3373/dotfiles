#!/usr/bin/env bash

current_dir=$(pwd)
_is_url=0
_is_file=0
_is_md=0
_is_html=0
_is_xlsx=0
_is_docx=0

has() { command -v "${1}" >&/dev/null; }
is_url() { [[ $_is_url -eq 1 ]]; }
is_file() { [[ $_is_file -eq 1 ]]; }
is_md() { [[ $_is_md -eq 1 ]]; }
is_html() { [[ $_is_html -eq 1 ]]; }
is_xlsx() { [[ $_is_xlsx -eq 1 ]]; }
is_docx() { [[ $_is_docx -eq 1 ]]; }
set_ostype() {
  _ostype=${OSTYPE}
  os wsl && _ostype=wsl
  os orb && _ostype=orb
}
set_open_command() {
  is_xlsx && has xleak && _open=xleak && return
  is_docx && has doxx && _open=doxx && return
  is_md && has wezterm && _open="wezterm cli spawn --cwd $(pwd) --new-window -- nvim -p" && return
  is_html && has chrome && _open=chrome && return
  _open=$(type -a open | grep -v "$0" | head -1 | cut -d' ' -f3)
  case "$_ostype" in
    cygwin*) _open=cygstart ;;
    msys*) _open=explorer ;;
    wsl*)
      _open=explorer.exe
      if is_url; then
        _open=cmd.exe
      fi
      ;;
    orb*) _open=/opt/orbstack-guest/bin/open ;;
    linux*)
      _open=xdg-open
      if ! is_url && has nautilus; then
        _open=nautilus
      fi
      ;;
  esac
}
set_args() {
  args=("$@")
  if [[ $# -eq 0 ]]; then
    args=("$current_dir")
  fi
  arg="${args[0]}"
  if [[ $arg =~ ^https?://.* ]]; then
    _is_url=1
  fi
  if [[ -f $arg ]]; then
    _is_file=1
    if [[ $arg =~ ^.*.md ]]; then
      _is_md=1
    fi
    if [[ $arg =~ ^.*.html ]]; then
      _is_html=1
    fi
    if [[ $arg =~ ^.*.xlsx? ]]; then
      _is_xlsx=1
    fi
    if [[ $arg =~ ^.*.docx? ]]; then
      _is_docx=1
    fi
  fi

  case "$_ostype" in
    cygwin | msys) args=("$(cygpath -aw "${args[@]}")") ;;
    wsl)
      if is_url; then
        args=("/C" "start" "${args[@]}")
      else
        args=("$(wslpath -w "${args[@]}")")
      fi
      ;;
  esac
}
open_forward_if_remote_detected() {
  [[ -n "${REMOTEHOST}${SSH_CONNECTION}" ]] || return 1
  port=${REMOTE_FORWARD_REVERSE_PORT}
  [[ -z $port ]] && return 1
  if [[ $_is_url -ne 1 && $_is_file -ne 1 ]]; then
    return 1
  fi
  arg="${args[0]}"
  if [[ $_is_file -eq 1 ]]; then
    scp "$arg" reverse:.dot/.trash/
    arg=".dot/.trash/$(basename "$arg")"
  fi
  # shellcheck disable=SC2029
  ssh reverse "open $arg" &>/dev/null &
  return 0
}
main() {
  local _ostype args _open
  set_ostype
  set_args "$@"
  open_forward_if_remote_detected || return
  set_open_command
  echo "==> open via $_open ${args[*]}" 1>&2
  $_open "${args[@]}" &>/dev/null &
}
main "$@"
