#!/usr/bin/env bash

current_dir=$(pwd) && readonly current_dir
readonly r=reverse
readonly rroot=.dot/.trash

has() { command -v "${1}" >&/dev/null; }
hass() { for _arg in "$@"; do has "$_arg" || die "==> No $_arg command exist."; done; }
_ink() { if has ink; then ink "$@"; else cat - 1>&2; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
die() { _log red "$*" && exit 1; }
is_url() { [[ $1 =~ ^https?://.* ]]; }

open_remote_if_detected() {
  [[ -n "${REMOTEHOST}${SSH_CONNECTION}" ]] || return 1
  [[ -z $REMOTE_FORWARD_REVERSE_PORT ]] && die "==> No REMOTE_FORWARD_REVERSE_PORT env var found, cannot open remotely."
  [[ ${#files[@]} -eq 0 && ${#urls[@]} -eq 0 ]] && die "==> No urls or files to open remotely."
  if [[ ${#files[@]} -gt 0 ]]; then
    scp "${files[@]}" $r:$rroot/ &>/dev/null || {
      die "==> Failed to send files to remote"
    }
  fi
  # shellcheck disable=SC2029
  ssh reverse open "${urls[@]}" "${rfiles[@]}" &>/dev/null &
  return 0
}
main() {
  local urls=() files=() rfiles=()
  for arg in "$@"; do
    is_url "$arg" && urls+=("$arg") && continue
    [[ -f $arg ]] && {
      files+=("$arg")
      rfiles+=("$rroot/$(basename "$arg")")
    }
  done
  open_remote_if_detected && return
  [[ ${#files[@]} -eq 0 && ${#urls[@]} -eq 0 ]] && files=("$current_dir")
  [[ ${#urls[@]} -ne 0 ]] && chrome "${urls[@]}" &>/dev/null &
  [[ ${#files[@]} -eq 0 ]] && return

  _ostype=${OSTYPE}
  os wsl && _ostype=wsl
  os orb && _ostype=orb
  _open=$(type -a open | grep -v "$0" | head -1 | cut -d' ' -f3)
  case "$_ostype" in
    cygwin*) _open=cygstart ;;
    msys*) _open=explorer ;;
    wsl*) _open=explorer.exe ;;
    orb*) _open=/opt/orbstack-guest/bin/open ;;
    linux*)
      _open=xdg-open
      if has nautilus; then
        _open=nautilus
      fi
      ;;
  esac

  for f in "${files[@]}"; do
    local mds=() imgs=() htmls=() xlsx=() docx=() others=()
    case "${f}" in
      *.md) mds+=("${f}") ;;
      *.html) htmls+=("${f}") ;;
      *.png | *.jpg | *.jpeg | *.gif | *.bmp | *.webp) has qimgv && imgs+=("${f}") || others+=("${f}") ;;
      *.xlsx | *.xls) has xleak && xlsx+=("${f}") || others+=("${f}") ;;
      *.docx | *.doc) has doxx && docx+=("${f}") || others+=("${f}") ;;
      *) others+=("${f}") ;;
    esac
  done
  [[ ${#mds[@]} -ne 0 ]] && wezterm cli spawn --cwd "$(pwd)" --new-window -- nvim -p "${mds[@]}" &>/dev/null &
  [[ ${#imgs[@]} -ne 0 ]] && qimgv "${imgs[@]}" &>/dev/null &
  [[ ${#htmls[@]} -ne 0 ]] && chrome "${htmls[@]}" &>/dev/null &
  [[ ${#xlsx[@]} -ne 0 ]] && xleak "${xlsx[@]}" &>/dev/null &
  [[ ${#docx[@]} -ne 0 ]] && doxx "${docx[@]}" &>/dev/null &
  [[ ${#others[@]} -ne 0 ]] && $_open "${others[@]}" &>/dev/null &
}
main "$@"
