#!/usr/bin/env bash

readonly depends=(curl fzf jq)
command_name=$(basename "$0") && readonly command_name
worktree_dir_name="-worktree" && readonly worktree_dir_name
grep_key_task_exists='- \[ \]' && readonly grep_key_task_exists
grep_key_task_completed='- \[[xX]\]' && readonly grep_key_task_completed
args=()
mode=list
target_dir=
comment_type=
comment_file=

usage() {
  cat <<EOF

Manage repository tasks.

  Usage:
      $command_name [option]
    Options
      -h|--help           : Show this usage
      -d|--directory      : Show task directory
      -s|--split          : Split tasks into multiple files
      -sa|--split-all     : Split all tasks into multiple files
      -n|--next           : Show next task chunk
      -c|--clean          : Move completed tasks to .tasks/done/done.md
      ok|v|done|complete  : Mark next task chunk as completed
      -m|--comment [type] : Add comment to first task (type: requirement|review|complete)
      -f|--file [path]    : Specify file to read comment content from (use with -m)
      --summary           : Show title of tasks
EOF
}

initialize() {
  while true; do
    [[ -z $1 ]] && break
    case "$1" in
      -h | --help) usage && exit 0 ;;
      -d | --directory) shift && target_dir=$1 ;;
      -s | --split) mode="split" ;;
      -sa | --split-all) mode="split-all" ;;
      -n | --next) mode="next" ;;
      -c | --clean) mode="clean" ;;
      -m | --comment)
        if [[ -z ${2:-} ]]; then
          error "==> -m|--comment requires a type argument: requirement|review|complete"
        fi
        shift && comment_type=$1 && mode="comment"
        ;;
      -f | --file) shift && comment_file=$1 ;;
      ok | v | done | complete) mode="complete" ;;
      --summary) mode="summary" ;;
      *) add_args "$1" ;;
    esac
    shift
  done
  check
  set -euo pipefail
}
check() { hass "${depends[@]}"; }
add_args() { args+=("$@"); }
has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || error "==> No $arg command exist."; done; }
_ink() { cat - | if has ink; then ink "$@"; else cat -; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
error() { _log red "$*" && exit 1; }
current_is_worktree_dir() { [[ $git_root =~ ^.*${worktree_dir_name}/.*$ ]]; }

initialize_links_if_needed() {
  [[ -e $target_file ]] && return

  if current_is_worktree_dir; then
    init_link_tasks_for_worktree
    return
  fi

  # Initialize if Not exist and Not in worktree directory
  init_link_tasks
}

init_link_tasks() {
  info "==> Initialize tasks for repository root directory.."
  repo_name=$(basename "$git_root")
  srcd="$HOME/.mo/tasks/$repo_name"
  info "==> Creating tasks directory at $srcd"
  mkdir -p "$srcd"/tasks/done
  touch "$srcd"/tasks.md
  info "==> Linking .tasks/ directory to $git_root"
  ln -s "$srcd/tasks" "$git_root/.tasks"
  info "==> Linking .tasks.md to $git_root"
  ln -s "$srcd/tasks.md" "$git_root/.tasks.md"
}

init_link_tasks_for_worktree() {
  info "==> Initialize tasks for worktree directory.."
  worktree_name=$(basename "$git_root")
  # repo_name=$(basename "${git_root%%/.git/*}")
  worktree_root_name=$(basename "$(dirname "$git_root")")
  repo_name=${worktree_root_name%"$worktree_dir_name"}
  srcd="$HOME/.mo/tasks/$repo_name"
  src_tasks_dir="$srcd/tasks"

  info "==> Creating tasks directory at $srcd"
  mkdir -p "$src_tasks_dir"/done
  touch "$srcd"/tasks.md

  src_tasks_md="$src_tasks_dir/$worktree_name.md"
  touch "$src_tasks_md"
  dst_tasks_md="$git_root/.tasks.md"
  info "==> Linking $src_tasks_md to $dst_tasks_md"
  ln -s "$src_tasks_md" "$dst_tasks_md"

  dst_tasks_dir="$git_root/.tasks"
  if [[ ! -e $dst_tasks_dir ]]; then
    info "==> Linking $src_tasks_dir to $dst_tasks_dir"
    ln -s "$src_tasks_dir" "$dst_tasks_dir"
  fi
}

find_tasks() {
  echo .tasks.md
  rg --files .tasks/ | sort
}

cat_first_task() {
  # awk '
  #   /^- / {
  #     if (in_task) {
  #       exit
  #     }
  #   }
  #   /^- \[ \]/ {
  #     in_task = 1
  #     print
  #     next
  #   }
  #   {
  #     if (in_task) {
  #       print
  #     }
  #   }
  # ' "$target_file"
  # parse_first_task
  parse_tasks 0
  sed -n "${first_line},${end_line}p" "$target_file"
}

# parse_first_task() {
#   if [[ ! -s $target_file ]] || ! grep -qE '^- \[ \]' "$target_file"; then
#     error "==> Empty tasks. $target_file"
#   fi

#   # チェックボックス行の行番号を取得
#   line_numbers=$(grep -nE '^- \[ \]' "$target_file" | cut -d: -f1)

#   # 最初の行番号を取得
#   first_line=$(echo "$line_numbers" | head -n1)

#   # 2番目の行番号を取得（なければファイル末尾）
#   second_line=$(echo "$line_numbers" | sed -n '2p')
#   if [[ -z $second_line ]]; then
#     second_line=$(($(wc -l <"$target_file") + 1))
#   fi

#   # 範囲を計算（2番目の直前まで）
#   end_line=$((second_line - 1))
# }

parse_tasks() {
  comp=$1
  grep_key=$grep_key_task_exists
  [[ $comp -eq 1 ]] && grep_key=$grep_key_task_completed
  if [[ ! -s $target_file ]] || ! grep -qE "^$grep_key" "$target_file"; then
    error "==> Empty tasks."
  fi

  read -r first_line second_line <<<"$(
    grep -nE '^- ' "$target_file" |
      grep -A1 -E "[0-9]+:$grep_key" |
      head -2 |
      cut -d: -f1 |
      tr '\n' ' '
  )"

  # 2番目の行番号がなければファイル末尾
  if [[ -z $second_line ]]; then
    second_line=$(($(wc -l <"$target_file") + 1))
  fi

  # 範囲を計算（2番目の直前まで）
  end_line=$((second_line - 1))
}

split_tasks() {
  # tempファイルに抽出
  local temp_file
  temp_file=$(mktemp)
  cat_first_task >"$temp_file"

  # 元ファイルから削除
  sed -i "${first_line},${end_line}d" "$target_file"

  # prpコマンドでJSON取得
  local json_result
  json_result=$(cat "$temp_file" | prp -ne gen-task-title-and-branch.md$ | llm -c tgpt -p groq)

  # JSON解析
  local branch name title
  branch=$(echo "$json_result" | jq -r '.branch')
  name=$(echo "$json_result" | jq -r '.name')
  title=$(echo "$json_result" | jq -r '.title')

  # タスクファイル作成
  worktree_name=${branch/\//-}
  local task_file=".tasks/${worktree_name}_${name}.md"
  # NOTE: git_worktree -a で link まで貼られるので、事前にファイル作成しておく
  touch "$task_file"

  # worktree ブランチ作成
  local worktree_dir
  worktree_dir=$(git_worktree -a "${branch}")

  # マークダウン形式でファイル作成
  cat >"$task_file" <<EOF
## ${title}
### ブランチ名
- ${branch}
### 作業ディレクトリ
- ${worktree_dir}
### タスク内容
$(cat "$temp_file")
EOF

  # link task_file
  ln -s "$(realpath "$git_root/$task_file")" "$worktree_dir/.tasks.md"
  if [[ ! -e "$worktree_dir/.tasks" ]]; then
    ln -s "$(realpath "$git_root/.tasks")" "$worktree_dir/.tasks"
  fi

  # tempファイル削除
  rm -f "$temp_file"

  info "==> Task split to: $task_file"
  info "==> Branch: $branch"
}

split_tasks_all() {
  split_tasks
  # まだタスクが残っていれば再帰的に処理
  if has_tasks; then
    split_tasks_all
  fi
}

has_tasks() {
  grep -qE "^$grep_key_task_exists" "$target_file"
}

has_completed_tasks() {
  grep -qE "^$grep_key_task_completed" "$target_file"
}

clean_tasks() {
  if current_is_worktree_dir; then
    real_task_file=$(realpath "$git_root/.tasks.md")
    real_done_dir=$(realpath "$git_root/.tasks/done")
    if [[ ! -e $real_task_file ]] || [[ ! -e $real_done_dir ]]; then
      error "==> Invalid state. real_task_file=$real_task_file, real_done_dir=$real_done_dir"
    fi
    # TODO dst is exist
    info "==> Moving $real_task_file to $real_done_dir/"
    mv -v "$real_task_file" "$real_done_dir/"
    worktree_name=$(basename "$git_root")
    find "$git_root/.tasks/" -maxdepth 1 -mindepth 1 -type f -name "${worktree_name}_*.md" -exec mv -v {} "$git_root/.tasks/done/" \;
    return
  fi

  local done_file="$git_root/.tasks/done/done.md"
  parse_tasks 1
  sed -n "${first_line},${end_line}p" "$target_file" | tee -a "$done_file"
  # 元ファイルから削除
  sed -i "${first_line},${end_line}d" "$target_file"

  # まだタスクが残っていれば再帰的に処理
  if has_completed_tasks; then
    clean_tasks
    return
  fi
  info "==> Task cleaned"
}

complete_task() {
  local complete_mark="✅️"
  first_line=$(head -1 "$target_file")
  if [[ $first_line =~ ^#+\ (.*)$ ]]; then
    if ! has_tasks; then
      complete_title_task
      return
    fi
  fi
  complete_normal_task
}

complete_title_task() {
  completed=0
  if echo "$first_line" | grep -qE $complete_mark; then
    warn "==> Task already marked as completed."
    completed=1
  fi
  if [[ $completed -eq 0 ]]; then
    sed -i "1s/^## \(.*\)$/## $complete_mark \1/" "$target_file"
    info "==> $complete_mark Task title marked as completed"
  fi
  # show target task title
  sed -n "1p" "$target_file"
}

complete_normal_task() {
  # はじめに見つかるタスクを完了にする
  parse_tasks 0
  # タスクを完了にする
  sed -i "${first_line}s/^- \[ \]/- [x]/" "$target_file"
  info "==> $complete_mark Task marked as completed"
  sed -n "${first_line}p" "$target_file"
}

get_comment_header() {
  case "${comment_type}" in
    requirement) echo "🎭 要件(ふるまい)" ;;
    review) echo "👍 レビュー修正" ;;
    complete) echo "✅ 完了" ;;
    *) error "==> Invalid comment type: ${comment_type}. Use: requirement|review|complete" ;;
  esac
}

comment_task() {
  local header
  header=$(get_comment_header)

  local input_content
  if [[ -n ${comment_file} ]]; then
    if [[ ! -f ${comment_file} ]]; then
      error "==> File not found: ${comment_file}"
    fi
    input_content=$(cat "${comment_file}")
  fi

  if [[ -z ${input_content:-} ]]; then
    if [[ -t 0 ]]; then
      error "==> No input. Usage: echo 'comment' | tasks -m ${comment_type} or tasks -m ${comment_type} -f <file>"
    fi
    input_content=$(cat)
  fi

  if [[ -z ${input_content} ]]; then
    error "==> Empty input."
  fi

  parse_tasks 0

  local temp_file
  temp_file=$(mktemp)
  trap 'rm -f "${temp_file}"' EXIT

  echo "  - ${header}" >"${temp_file}"
  while IFS= read -r line; do
    echo "    ${line}" >>"${temp_file}"
  done <<<"${input_content}"

  sed -i "${end_line}r ${temp_file}" "${target_file}"
  rm -f "${temp_file}"
  trap - EXIT

  info "==> Comment added to task"
}

summary_tasks() {
  task_dir_name=$(basename "$git_root")
  # タスクの概要を抽出して表示
  first_line=$(head -1 "$target_file")
  task_summary=
  if [[ -n $first_line && $first_line =~ ^(#)+\ .*$ ]]; then
    task_summary=" [${first_line##*# }]"
  fi
  echo "$task_dir_name$task_summary"
}

main() {
  initialize "$@"

  git_root="$target_dir"
  if [[ -z $git_root ]]; then
    # git_rootはworktree内にいる場合はそのworktreeのルートを指す
    git_root=$(git rev-parse --show-toplevel)
  fi
  cd "$git_root" || exit 1

  target_file="$git_root/.tasks.md"
  initialize_links_if_needed
  # NOTE: fix sed -i overwrite symlink and break link, so use realpath
  target_file=$(realpath "$target_file")

  if [[ $mode == "next" ]]; then
    cat_first_task
    return
  fi
  if [[ $mode == "split" ]]; then
    split_tasks
    return
  fi
  if [[ $mode == "split-all" ]]; then
    split_tasks_all
    return
  fi
  if [[ $mode == "clean" ]]; then
    clean_tasks
    return
  fi
  if [[ ${mode} == "comment" ]]; then
    comment_task
    return
  fi
  if [[ $mode == "complete" ]]; then
    complete_task
    return
  fi
  if [[ $mode == "summary" ]]; then
    summary_tasks
    return
  fi

  find_tasks | v
}
main "$@"
