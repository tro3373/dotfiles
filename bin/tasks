#!/usr/bin/env bash
# test: bin/lib/test/tasks
# ~/.config/tasks/config.env

readonly depends=(curl fzf jq tmux git_worktree bat)
readonly timestamp_fmt="+%Y%m%d-%H%M%S"
timestamp=$(date $timestamp_fmt) && readonly timestamp
command_name=$(basename "$0") && readonly command_name
# fzf preview から自分自身を再呼び出しするための絶対パス (symlink 解決済み)
self_path=$(realpath "$0") && readonly self_path
grep_key_task_exists='- \[ \]' && readonly grep_key_task_exists
grep_key_task_completed='- \[[xX]\]' && readonly grep_key_task_completed
# 参照行 (split 済みタスクへのリンク): `- [ ] [title](store_root相対path)` 形式
grep_key_reference='^- \[[ xX]\] \[[^]]*\]\(' && readonly grep_key_reference
# 完了済み参照行のみ (clean 対象): `- [x] [title](path)`
grep_key_reference_done='^- \[[xX]\] \[[^]]*\]\(' && readonly grep_key_reference_done
# 完了マーク (title 接頭辞 / 完了ログ)。complete と split-completed で共用。
readonly complete_mark="✅️"
args=()
mode=list
comment_type=
task_file=
task_index=
task_index_explicit=0
# --all: Nth 選択可能コマンド (split/complete/spawn/clean) で全候補を選択する
select_all=0
parse_skip_refs=0
# spawn 対象 agent (-sp=claude / -spc=codex)。tmux 起動コマンドの分岐に使う。
spawn_agent=claude
# config (load_tasks_config が設定): store_root=絶対, tasks_subdir=相対, log_fmt=相対フォーマット
store_root=
tasks_subdir=
log_fmt=
tasks_store_dir=

usage() {
  cat <<EOF

Manage repository tasks.

  Usage:
      $command_name [option] [N]
    Options
      -h|--help           : Show this usage
      -s|--split          : Split task(s) into a task dir + worktree (fzf if no N)
      -n|--next           : Show Nth task chunk (default 1; also -n2, --next=2)
      -c|--clean          : Record completed task(s) to log and drop them (fzf if no N)
      ok|v|done|complete  : Mark task(s) as completed (fzf if no N)
      -m|--comment [type] : Add comment to Nth task (type: requirement|review|complete)
      -a|--add            : Add task from stdin (prepends "- [ ] " if missing)
      -f|--file [path]    : Specify task file to operate on (default: repo .tasks.md)
      -sp|--spawn         : Spawn worktree + tmux + CC /task (split first if needed; fzf if no N)
      -spc|--spawn-codex  : Spawn like --spawn but launch Codex (\$task) instead of Claude
      --all               : Select all candidates for split/complete/spawn/clean
      --summary           : Show title of tasks
    Task index [N]
      next/comment use the Nth pending task (1-based, default 1).
      split/complete/spawn/clean use N directly; omit N to pick via fzf
      multi-select (ctrl-l: toggle-all, ctrl-g: toggle-preview); --all selects
      all without fzf. Give N as 2 or -2.
EOF
}

initialize() {
  while true; do
    [[ -z $1 ]] && break
    case "$1" in
      -h | --help) usage && exit 0 ;;
      -s | --split) mode="split" ;;
      -n | --next)
        mode="next"
        if [[ ${2:-} =~ ^[0-9]+$ ]]; then
          shift && task_index=$1
        fi
        ;;
      -n[0-9]*)
        mode="next"
        task_index=${1#-n}
        [[ $task_index =~ ^[1-9][0-9]*$ ]] || die "==> Invalid option: $1"
        ;;
      --next=*)
        mode="next"
        task_index=${1#--next=}
        [[ $task_index =~ ^[1-9][0-9]*$ ]] || die "==> Invalid option: $1"
        ;;
      -c | --clean) mode="clean" ;;
      --all) select_all=1 ;;
      -m | --comment)
        if [[ -z ${2:-} ]]; then
          die "==> -m|--comment requires a type argument: requirement|review|complete"
        fi
        shift && comment_type=$1 && mode="comment"
        ;;
      -a | --add) mode="add" ;;
      -f | --file)
        if [[ -z ${2:-} ]]; then
          die "==> -f|--file requires a path argument"
        fi
        shift && task_file=$1
        ;;
      ok | v | done | complete) mode="complete" ;;
      -sp | --spawn) mode="spawn" ;;
      -spc | --spawn-codex) mode="spawn" && spawn_agent="codex" ;;
      --summary) mode="summary" ;;
      --preview-line)
        # fzf preview 専用 (内部用)。指定行のタスクブロック/参照先を表示する。
        mode="preview"
        shift && task_index=$1
        ;;
      -[0-9]*)
        task_index=${1#-}
        [[ $task_index =~ ^[1-9][0-9]*$ ]] || die "==> Invalid option: $1"
        ;;
      [0-9]*)
        [[ $1 =~ ^[1-9][0-9]*$ ]] || die "==> Invalid index: $1"
        task_index=$1
        ;;
      -*) die "==> Invalid option: $1" ;;
      *) add_args "$1" ;;
    esac
    shift
  done
  [[ -n $task_index ]] && task_index_explicit=1
  check
  set -euo pipefail
}
check() {
  hass "${depends[@]}"
  if [[ -z $task_file ]]; then
    git rev-parse --is-inside-work-tree &>/dev/null || die "==> Not inside a git worktree."
  fi
}
add_args() { args+=("$@"); }
has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || die "==> No $arg command exist."; done; }
_ink() { cat - | if has ink; then ink "$@"; else cat -; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
die() { _log red "$*" && exit 1; }
# linked worktree では git-common-dir(共有 .git) と git-dir(worktree 個別) が食い違う。
# パス命名規約に依存しない判定 (git_worktree の is_invoked_from_worktree と同方式)。
current_is_worktree_dir() {
  local common gitdir
  common=$(git -C "$git_root" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  gitdir=$(git -C "$git_root" rev-parse --path-format=absolute --git-dir 2>/dev/null) || return 1
  [[ $common != "$gitdir" ]]
}
get_timestamp_prefix() { date +"[%Y%m%d_%H%M%S]"; }
# 絶対パスの先頭 $HOME を ~ に畳む / ~ を $HOME に展開する。
# 参照や parent をユーザ名非依存の ~ 形式で保存し、利用時に展開する。
to_tilde() { printf '%s' "${1/#$HOME/\~}"; }
from_tilde() { printf '%s' "${1/#\~/$HOME}"; }
# 参照行 `- [ ] [title](path)` とパスの相互変換 (to_tilde/from_tilde と同様の対)。
# title は path のタスクディレクトリ名 (basename of dirname) を SSOT として導出。
# from は完了状態 `- [x] [title](path)` のパスも取り出せる。
to_reference_line() {
  local path="$1" title
  title=$(basename "$(dirname "$path")")
  printf '%s' "- [ ] [$title]($path)"
}
from_reference_line() { sed -E 's/^- \[[ xX]\] \[[^]]*\]\((.*)\)$/\1/' <<<"$1"; }

# 参照行のパス (store_root 相対 / ~ / 絶対) を絶対実パスへ解決する。
# ~ 展開と store_root 相対補完を施し symlink も解決する (worktree .tasks.md 表記対応)。
# 解決できなければ非ゼロを返す (呼び出し側で該当行を skip)。
resolve_reference_path() {
  local p
  p=$(from_tilde "$1")
  [[ $p == /* ]] || p="$store_root/$p"
  realpath "$p" 2>/dev/null
}

# log_fmt の strftime 指定子 (%Y, %Y-%m 等) を date で実値化する。
expand_log_fmt() { date +"$1"; }

# 実行日の日付別ログの絶対パスを返す (store_root 起点で log_fmt を実値化)。
# 内容日付が判定できないときの reference_log_path のフォールバック先。
current_log_path() { printf '%s\n' "$store_root/$(expand_log_fmt "$log_fmt")"; }

# YAML front matter を出力 (title, branch, name, parent)。done は常に false。
# body は呼び出し側で追記する。front matter スキーマの SSOT。
emit_front_matter() {
  local title="$1" branch="$2" name="$3" parent="$4"
  printf '%s\n' '---'
  printf 'title: %s\n' "$title"
  printf 'branch: %s\n' "$branch"
  printf 'name: %s\n' "$name"
  printf 'done: false\n'
  printf 'parent: %s\n' "$parent"
  printf '%s\n' '---'
  printf '\n'
}

# .tasks.md(file) と .tasks(dir) のリンクが無ければ生成。
# not worktree: {tasks_subdir}/{repo}/index.md を生成し .tasks.md => index.md
# worktree    : 親リポと共有 base を使い worktree 専用 .tasks.md を自己修復
initialize_links_if_needed() {
  dst_tasks_md="$git_root/.tasks.md"
  dst_tasks_dir="$git_root/.tasks"
  [[ -e $dst_tasks_md && -e $dst_tasks_dir ]] && return

  if current_is_worktree_dir; then
    initialize_worktree_links
    return
  fi
  initialize_normal_links
}

initialize_normal_links() {
  info "==> Initialize tasks files.."
  local repo_name repo_tasks_dir repo_tasks_md
  repo_name=$(basename "$git_root")
  repo_tasks_dir="$tasks_store_dir/$repo_name"
  repo_tasks_md="$repo_tasks_dir/index.md"
  if [[ ! -e $dst_tasks_dir ]]; then
    mkdir -p "$repo_tasks_dir"
    _ln "$repo_tasks_dir" "$dst_tasks_dir"
  fi
  if [[ ! -e $dst_tasks_md ]]; then
    touch "$repo_tasks_md"
    _ln "$repo_tasks_md" "$dst_tasks_md"
  fi
}

# worktree のリンクを自己修復する。親リポを git-common-dir から逆引きし
# {tasks_subdir}/{repo} を親と共有する base として使う。worktree のブランチは
# 確定済みなので LLM 推論なしで split と同型の front matter を決定的に生成する。
initialize_worktree_links() {
  info "==> Initialize worktree tasks files.."
  local org_root repo_name base_dir branch name wt_ts wt_md wt_dir
  org_root=$(dirname "$(git -C "$git_root" rev-parse --path-format=absolute --git-common-dir)")
  repo_name=$(basename "$org_root")
  base_dir="$tasks_store_dir/$repo_name"
  mkdir -p "$base_dir"

  branch=$(git -C "$git_root" rev-parse --abbrev-ref HEAD)
  [[ -z $branch || $branch == "HEAD" ]] && branch=$(basename "$git_root")
  name=${branch//\//-}
  wt_ts=$(date -r "$git_root" $timestamp_fmt)
  wt_dir="$base_dir/${wt_ts}_${name}"
  mkdir -p "$wt_dir"
  wt_md="$wt_dir/index.md"
  [[ -e $wt_md ]] ||
    emit_front_matter "$branch" "$branch" "$name" "$(to_tilde "$(realpath "$org_root/.tasks.md")")" >"$wt_md"
  [[ -e $dst_tasks_dir ]] || _ln "$base_dir" "$dst_tasks_dir"
  [[ -e $dst_tasks_md ]] || _ln "$wt_md" "$dst_tasks_md"
}

# config から store_root/tasks_subdir/log_fmt を読み込む。SSOT は config。
# tasks_store_dir = store_root/tasks_subdir。main から全モード共通で1回だけ呼ぶ。
# log_fmt は strftime 指定子を含むパスフォーマット (ex: log_fmt=logs/%Y/%Y-%m-01-log.md)。
load_tasks_config() {
  local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/tasks/config.env"
  [[ -f $config_file ]] ||
    die "==> No config: $config_file => Define store_root, tasks_subdir, log_fmt"
  # shellcheck source=/dev/null
  source "$config_file" ||
    die "==> Failed to load config (syntax error?): $config_file"
  [[ -n ${store_root:-} ]] || die "==> 'store_root' is not set in $config_file"
  [[ -n ${tasks_subdir:-} ]] || die "==> 'tasks_subdir' is not set in $config_file"
  [[ -n ${log_fmt:-} ]] || die "==> 'log_fmt' is not set in $config_file"
  store_root=$(from_tilde "$store_root")
  [[ $store_root == /* ]] ||
    die "==> 'store_root' must be an absolute path: $store_root"
  store_root=$(realpath -m "$store_root")
  tasks_store_dir="$store_root/$tasks_subdir"
}

_ln() {
  info "==> Linking $1 to $2"
  ln -s "$1" "$2"
}

find_tasks() {
  echo .tasks.md
  find .tasks/ -maxdepth 1 -mindepth 1 -type f -name '*.md' 2>/dev/null | sort -nr || :
}

cat_first_task() {
  parse_tasks 0 "$task_index"
  sed -n "${first_line},${end_line}p" "$target_file"
}

# 候補タスク行 (lineno:行内容) を返す。comp=1 で完了タスク (- [x])、それ以外は未完了 (- [ ])。
# skip_refs=1 で参照行 (- [ ] [title](path)) を候補から除外する。die を持たず $() 内で安全。
list_task_lines() {
  local comp="$1" skip_refs="$2" key lines
  key=$grep_key_task_exists
  [[ $comp -eq 1 ]] && key=$grep_key_task_completed
  lines=$(grep -nE "^$key" "$target_file" 2>/dev/null || :)
  if [[ $skip_refs -eq 1 ]]; then
    lines=$(printf '%s\n' "$lines" | { grep -vE "^[0-9]+:${grep_key_reference#^}" || :; })
  fi
  printf '%s\n' "$lines" | sed '/^$/d'
}

# 指定行をタスク先頭として first_line/end_line をセットする (グローバル)。
# 終端 = 以降最初の `- ` 行 or 見出し行(#) の直前。無ければファイル末尾。
set_block_range() {
  first_line="$1"
  second_line=$(grep -nE '^(- |#)' "$target_file" | awk -F: -v fl="$first_line" '$1 > fl {print $1; exit}')
  [[ -n $second_line ]] || second_line=$(($(wc -l <"$target_file") + 1))
  end_line=$((second_line - 1))
}

parse_tasks() {
  comp=$1
  local index=${2:-1} fl
  grep_key=$grep_key_task_exists
  [[ $comp -eq 1 ]] && grep_key=$grep_key_task_completed
  if [[ ! -s $target_file ]] || ! grep -qE "^$grep_key" "$target_file"; then
    die "==> Empty tasks."
  fi
  fl=$(list_task_lines "$comp" "$parse_skip_refs" | sed -n "${index}p" | cut -d: -f1)
  [[ -n $fl ]] || die "==> Task index ${index} not found."
  set_block_range "$fl"
}

# stdin を markdown としてシンタックスハイライト表示する (fzf preview 用)。
# $1 = ヘッダに出すファイル名ラベル (stdin パイプだと既定の STDIN が無意味なため)。
_bat_md() {
  bat --language=md --color=always --style=full --paging=never --file-name="$1"
}

# fzf preview 用: 指定行のタスクを表示する。参照行 (- [ ] [title](path)) なら
# 参照先 index.md の中身を、実ブロックなら set_block_range で求めた当該ブロック
# (次の `- `/`#` 直前まで) を表示する。固定行数でなくブロック境界に従う。
preview_line() {
  local line_no="$1" line ref_path index_md
  line=$(sed -n "${line_no}p" "$target_file")
  if printf '%s\n' "$line" | grep -qE "$grep_key_reference"; then
    ref_path=$(from_reference_line "$line")
    index_md="$store_root/$ref_path"
    if [[ -e $index_md ]]; then
      _bat_md "$ref_path" <"$index_md"
      return
    fi
    printf '%s\n' "$line" | _bat_md "$ref_path"
    return
  fi
  set_block_range "$line_no"
  sed -n "${first_line},${end_line}p" "$target_file" | _bat_md "$(basename "$target_file")"
}

# bin/v 互換 keybind の multi-select fzf。stdin=候補(lineno:行内容)、$1=prompt。
# 表示は行番号列を隠し、preview は当該ブロック (参照行は参照先 index.md) を表示する。
# preview は自分自身を --preview-line で再呼び出しし、ブロック境界解決を共有する。
fzf_select() {
  fzf --multi --reverse --height=80% \
    --delimiter=: --with-nth=2.. \
    --prompt="$1" \
    --preview "'$self_path' -f '$target_file' --preview-line {1}" \
    --bind 'ctrl-l:toggle-all,ctrl-g:toggle-preview'
}

# 候補(lineno:行内容)から選択行を返す。--all 時は全件、Nth 明示時は N 番目、
# どちらも無ければ fzf。die を持たないため $() 内で安全 (空チェック die は呼び出し側)。
choose_lines() {
  local candidates="$1" prompt="$2"
  if [[ $select_all -eq 1 ]]; then
    printf '%s\n' "$candidates"
    return
  fi
  if [[ $task_index_explicit -eq 1 ]]; then
    printf '%s\n' "$candidates" | sed -n "${task_index}p"
    return
  fi
  printf '%s\n' "$candidates" | fzf_select "$prompt"
}

# 選択行(lineno:行内容)を行番号降順で fn に行番号を渡して実行する。
# 降順処理で、split のブロック→1行参照置換による行ずれが未処理タスクへ波及しない。
process_selected() {
  local selected="$1" fn="$2" sel
  while IFS= read -r sel; do
    [[ -n $sel ]] || continue
    "$fn" "${sel%%:*}"
  done < <(printf '%s\n' "$selected" | sort -t: -k1,1nr)
}

# タスク内容(stdin)から branch/name/title の JSON を生成する。
# テスト用に TASKS_GEN_META_CMD で生成コマンドを差し替え可能 (stdin を読み JSON を出力)。
gen_task_meta() {
  if [[ -n ${TASKS_GEN_META_CMD:-} ]]; then
    "${TASKS_GEN_META_CMD}"
    return
  fi
  prp -ne 'gen-task-title-and-branch.md$' | llm -c tgpt -p groq -fc claude
}

# tmp_file(タスク本文) と ts から split 先 index.md を構築する共通処理。
# meta 生成・検証・dir 作成・front matter 書き出し・ref 算出を 1 箇所に集約する。
# 出力はグローバル: task_branch / task_index_md / task_ref (store_root 相対)。
# done マーク・関連ファイル移動・参照行のチェック状態は呼び出し側の責務。
write_split_index() {
  local tmp_file="$1" ts="$2" json_result name title base_dir task_dir parent_md
  json_result=$(gen_task_meta <"$tmp_file")
  task_branch=$(echo "$json_result" | jq -r '.branch')
  name=$(echo "$json_result" | jq -r '.name')
  title=$(echo "$json_result" | jq -r '.title')
  if [[ -z $task_branch || -z $name || -z $title || $task_branch == null ]]; then
    die "==> Invalid task meta JSON: $json_result"
  fi

  # タスクディレクトリ: {tasks_subdir}/{repo}/{ts}_{name}/index.md
  # .tasks は {tasks_subdir}/{repo} を指す symlink
  base_dir=$(realpath "$git_root/.tasks")
  task_dir="$base_dir/${ts}_${name}"
  mkdir -p "$task_dir"
  task_index_md="$task_dir/index.md"
  parent_md=$(to_tilde "$(realpath "$git_root/.tasks.md")")

  # YAML front matter + タスク内容
  {
    emit_front_matter "$title" "$task_branch" "$name" "$parent_md"
    cat "$tmp_file"
  } >"$task_index_md"

  # ref は store_root 相対パス
  task_ref=${task_index_md#"$store_root"/}
  [[ $task_ref != /* ]] ||
    die "==> Task path not under store_root: $task_index_md (store_root=$store_root)"
}

# 選択タスクを {timestamp}_{name}/index.md へ split し、worktree も作成する。
# Nth 未指定なら fzf multi-select。複数選択は行番号降順で処理する。
split_task() {
  parse_skip_refs=1
  local candidates selected
  candidates=$(list_task_lines 0 1)
  [[ -n $candidates ]] || die "==> No splittable tasks in $target_file"
  # fzf キャンセルは非ゼロ終了。set -e で即死せず friendly die へ繋ぐため || true
  selected=$(choose_lines "$candidates" "Select task(s) to split: ") || true
  [[ -n $selected ]] || die "==> No task selected."
  process_selected "$selected" split_one_task
}

# 指定行のタスクブロックを split する (index.md 生成 + 参照行置換 + worktree 作成)。
# timestamp は split 実行時。元リストの当該タスクは参照行へ置換 (削除しない)。
split_one_task() {
  local line_no="$1" tmp_file
  set_block_range "$line_no"
  tmp_file=$(mktemp)
  sed -n "${first_line},${end_line}p" "$target_file" >"$tmp_file"
  write_split_index "$tmp_file" "$timestamp"
  replace_task_with_reference "$task_ref"
  rm -f "$tmp_file"
  info "==> Task split to: $task_index_md"
  info "==> Branch: $task_branch"
  ensure_worktree "$task_branch" "$task_index_md"
  info "==> Worktree: $worktree_dir"
}

# first_line..end_line のタスクブロックを 1 行の参照リンク文字列に置換する (低レベル)
replace_block_with_reference_line() {
  local ref_line="$1"
  sed -i "${first_line},${end_line}c\\
${ref_line}" "$target_file"
}

# split: 未完了タスクブロックを未完了参照行 (- [ ]) へ置換する
replace_task_with_reference() {
  replace_block_with_reference_line "$(to_reference_line "$1")"
}

# clean 用: 指定行の未 split 完了タスク (- [x] 実ブロック) を split する。
# ブロックを {ts}_{name}/index.md (done:true) へ移し、関連ファイルを移動し、
# 元リストは first_line に完了参照行 (- [x] [name](path)) を残す。
split_completed_one() {
  info "==> Splitting LineNo: $line_no.."
  local line_no="$1" tmp_file ts ref_line src_dir
  set_block_range "$line_no"
  tmp_file=$(mktemp)
  sed -n "${first_line},${end_line}p" "$target_file" >"$tmp_file"

  # dir の timestamp はブロック内最新 [YYYYMMDD_HHMMSS]。無ければ内容日付不明として
  # 警告し clean 実行時 (今日) へフォールバックする。
  ts=$(extract_latest_ts "$tmp_file")
  if [[ -z $ts ]]; then
    warn "==> Cannot determine entry date (no [YYYYMMDD_HHMMSS] in block), using today: $(head -1 "$tmp_file")"
    ts=$timestamp
  fi

  write_split_index "$tmp_file" "$ts"
  mark_front_matter_done "$task_index_md"

  # ブロック内に記載された関連ファイル (index.md と同一 dir に実在) を split 先へ移動
  src_dir=$(dirname "$target_file")
  move_related_files "$tmp_file" "$src_dir" "$(dirname "$task_index_md")"

  # 完了タスクなので参照行は完了状態 (- [x]) で生成する
  ref_line=$(to_reference_line "$task_ref")
  ref_line="- [x]${ref_line#"- [ ]"}"
  replace_block_with_reference_line "$ref_line"

  rm -f "$tmp_file"
  info "==> Completed task split to: $task_index_md"
}

# ブロック内の [YYYYMMDD_HHMMSS] (完了/要件問わず) の最新を YYYYMMDD-HHMMSS で返す。
# 該当無しは空文字 (呼び出し側で clean 実行時 timestamp へフォールバック)。
extract_latest_ts() {
  local file="$1"
  grep -oE '\[[0-9]{8}_[0-9]{6}\]' "$file" 2>/dev/null |
    tr -d '[]' | sort | tail -1 | tr '_' '-' || :
}

# ブロックに書かれたファイル名のうち src_dir に実在するものだけを dst_dir へ移動する。
# 抽出は決定的トークンマッチ (LLM 非使用)。src_dir (mo 配下の実 dir) は task 専用の
# metadata dir なので loose file は task 成果物のみ。repo 内の言及ファイル (README 等) は
# src_dir に無いので実在チェックで除外される。成果物の命名規約 ({TS}-...) には依存しない。
# index.md 自体は親リストなので常に除外する (実在するため巻き込み防止: load-bearing)。
move_related_files() {
  local block_file="$1" src_dir="$2" dst_dir="$3" f index_name
  index_name=$(basename "$target_file")
  while IFS= read -r f; do
    [[ $f == "$index_name" ]] && continue
    [[ -f "$src_dir/$f" ]] || continue
    mv "$src_dir/$f" "$dst_dir/"
    info "==> Moved related file: $f"
  done < <(grep -oE '[A-Za-z0-9._-]+\.[A-Za-z0-9]+' "$block_file" 2>/dev/null | sort -u)
}

has_tasks() {
  grep -qE "^$grep_key_task_exists" "$target_file"
}

has_front_matter() {
  head -1 "$target_file" | grep -qx -- '---'
}

# front matter から key の値を取得 (file, key)
front_matter_value() {
  local file="$1" key="$2"
  head -1 "$file" 2>/dev/null | grep -qx -- '---' || return 0
  awk -v k="$key" '
    NR==1 { infm=1; next }
    infm && $0=="---" { exit }
    infm && index($0, k": ")==1 { sub("^" k ": *",""); print; exit }
  ' "$file"
}

# 選択した未 split 完了インラインタスク (- [x]) を split して log_fmt へ転記する。
# 候補は未 split 完了タスクのみ (完了参照行は除外): split 済みタスクの完了は complete
# 時に mark_parent_reference_done が log 転記するため clean では扱わない。参照行は残す。
# Nth 未指定なら fzf multi-select、--all で全件。log_fmt は store_root を起点に解決する。
clean_tasks() {
  local candidates selected
  candidates=$(list_task_lines 1 1)
  if [[ -z $candidates ]]; then
    info "==> No completed tasks to clean."
    return 0
  fi
  selected=$(choose_lines "$candidates" "Select completed task(s) to clean: ") || true
  [[ -n $selected ]] || die "==> No task selected."
  process_selected "$selected" clean_one_task
  info "==> Recorded completed task references to date-based logs under $store_root"
}

# 指定行の完了タスクを clean する。複数行の未 split 完了ブロックは先に split し、
# 完了参照行を log へ転記する (参照行は残す / normal/worktree 共通)。
# 1 行のみ (本文なし) のタスクは split せず生の行を log へ転記し、リストから削除する。
clean_one_task() {
  local line_no="$1" line ref_line log_path
  line=$(sed -n "${line_no}p" "$target_file")
  if ! printf '%s\n' "$line" | grep -qE "$grep_key_reference_done"; then
    set_block_range "$line_no"
    if [[ $first_line -eq $end_line ]]; then
      log_path=$(reference_log_path "$line")
      append_reference_to_log "$log_path" "$line"
      sed -i "${first_line},${end_line}d" "$target_file"
      info "==> Recorded to $log_path (single-line, removed from list)"
      return
    fi
    split_completed_one "$line_no"
  fi
  ref_line=$(sed -n "${line_no}p" "$target_file")
  log_path=$(reference_log_path "$ref_line")
  append_reference_to_log "$log_path" "$ref_line"
  info "==> Recorded to $log_path"
}

# ref (完了参照行) の split timestamp (YYYYMMDD-HHMMSS) から内容日付 YYYYMMDD を取り出す。
# timestamp 無し (worktree symlink 参照等) は空。日付見出しと log パス解決の共用 SSOT。
reference_ymd() {
  local ts
  ts=$(grep -oE '[0-9]{8}[-_][0-9]{6}' <<<"$1" | head -1 || :)
  printf '%s' "${ts:0:8}"
}

# ref の内容日付から日付見出し '## %Y-%m-%d (%a)' を生成する。日付不明時は実行日。
# log をタスク日付別にグルーピングするための SSOT。
reference_date_header() {
  local ymd
  ymd=$(reference_ymd "$1")
  if [[ -n $ymd ]]; then
    date -d "$ymd" +'## %Y-%m-%d (%a)' 2>/dev/null && return
  fi
  date +'## %Y-%m-%d (%a)'
}

# ref の内容日付で日付別 log の絶対パスを返す (store_root 起点で log_fmt を実値化)。
# 内容日付が判定できなければ実行日の log (current_log_path) へフォールバックし警告する。
# 「転記先を転記する内容の日付で決める」ための SSOT。clean と complete で共用する。
reference_log_path() {
  local ref="$1" ymd fmt
  ymd=$(reference_ymd "$ref")
  if [[ -n $ymd ]] && fmt=$(date -d "$ymd" +"$log_fmt" 2>/dev/null); then
    printf '%s\n' "$store_root/$fmt"
    return
  fi
  # warn は stdout 出力。本関数は $() で値捕捉されるため警告は >&2 で stderr へ逃がす
  # (>&2 を外すと警告文が log_path に混入し誤パスを生む: load-bearing)。
  warn "==> Cannot determine entry date from reference, using today's log: $ref" >&2
  current_log_path
}

# 完了参照行を log へ転記する。ref の日付見出しが無ければ先に追加し、その配下へ ref を
# 追記する。見出し・ref とも既存なら追記しない (再実行冪等)。
append_reference_to_log() {
  local log_path="$1" ref="$2" header
  mkdir -p "$(dirname "$log_path")"
  header=$(reference_date_header "$ref")
  if ! grep -qxF -- "$header" "$log_path" 2>/dev/null; then
    printf '%s\n' "$header" >>"$log_path"
  fi
  if grep -qxF -- "$ref" "$log_path" 2>/dev/null; then
    return 0
  fi
  printf '%s\n' "$ref" >>"$log_path"
}

complete_task() {
  # front matter 持ち index.md は body の未完了サブタスクを先に消化し、
  # 残り 0 になった時点で title 全体を完了扱いにする (旧 complete_title_task 同等)
  if has_front_matter && ! has_tasks; then
    complete_front_matter_task
    return
  fi
  complete_normal_task
}

# front matter 持ち index.md を完了状態へ (done:true + title に ✅️)。冪等。
# complete と split-completed が対象ファイルを変えて共用するため引数で受ける。
mark_front_matter_done() {
  local file="$1"
  sed -i 's/^done: *false/done: true/' "$file"
  grep -qE "^title: *${complete_mark}" "$file" ||
    sed -i "s/^title: */&${complete_mark} /" "$file"
}

# split で生成した index.md (front matter 持ち) の完了処理
complete_front_matter_task() {
  if grep -qE '^done: *true' "$target_file"; then
    warn "==> Task already marked as completed."
    return 0
  fi
  mark_front_matter_done "$target_file"
  info "==> ${complete_mark} Task title marked as completed"
  grep -E '^title:' "$target_file" | head -1
  mark_parent_reference_done
}

# 親 index.md の当該参照行 (- [ ] [title](path)) を [x] 化し、日付別ログへ転記する。
# 参照行のパス表記は複数系統 (store_root 相対 index.md / worktree .tasks.md の ~ パス) が
# 混在しうるため、リテラル一致でなく解決後の絶対実パスで $target_file と突き合わせる。
# split タスク完了の記録は clean を介さずここで残す (transfer は冪等)。
mark_parent_reference_done() {
  local parent lineno line line_path log_path ref
  parent=$(from_tilde "$(front_matter_value "$target_file" parent)")
  [[ -n $parent && -e $parent ]] || return 0
  lineno=
  while IFS= read -r line; do
    line_path=$(resolve_reference_path "$(from_reference_line "${line#*:}")") || continue
    if [[ $line_path == "$target_file" ]]; then
      lineno=${line%%:*}
      break
    fi
  done < <(grep -nE "$grep_key_reference" "$parent" 2>/dev/null || :)
  [[ -n $lineno ]] || {
    warn "==> No parent reference exists in $parent"
    return 0
  }
  sed -i "${lineno}s/- \[ \]/- [x]/" "$parent"
  info "==> Parent reference marked done: $parent"
  ref=$(sed -n "${lineno}p" "$parent")
  log_path=$(reference_log_path "$ref")
  append_reference_to_log "$log_path" "$ref"
}

# 通常サブタスクを完了にする。Nth 未指定なら fzf multi-select。
# 参照行は手動完了せず mark_parent_reference_done 経由でのみ [x] 化する一本道にする。
complete_normal_task() {
  parse_skip_refs=1
  local candidates selected
  candidates=$(list_task_lines 0 1)
  [[ -n $candidates ]] || die "==> Empty tasks."
  selected=$(choose_lines "$candidates" "Select task(s) to complete: ") || true
  [[ -n $selected ]] || die "==> No task selected."
  process_selected "$selected" complete_one_task
}

# 指定行の未完了タスクを完了 (- [ ] => - [x]) にする。行数は変わらない。
complete_one_task() {
  local line_no="$1"
  sed -i "${line_no}s/^- \[ \]/- [x]/" "$target_file"
  info "==> $complete_mark Task marked as completed"
  sed -n "${line_no}p" "$target_file"
}

get_comment_header() {
  case "${comment_type}" in
    requirement) echo "$(get_timestamp_prefix) 🎭 要件(ふるまい)" ;;
    review) echo "$(get_timestamp_prefix) 👀 レビュー修正" ;;
    complete) echo "$(get_timestamp_prefix) 🎉 完了" ;;
    *) die "==> Invalid comment type: ${comment_type}. Use: requirement|review|complete" ;;
  esac
}

read_input_content() {
  input_content=
  if [[ -t 0 ]]; then
    die "==> No input from stdin."
  fi
  input_content=$(cat)

  if [[ -z ${input_content} ]]; then
    die "==> Empty input."
  fi
}

comment_task() {
  local header input_content
  header=$(get_comment_header)

  read_input_content

  parse_tasks 0 "$task_index"

  local temp_file
  temp_file=$(mktemp)
  trap 'rm -f "${temp_file}"' EXIT

  echo "  - ${header}" >"${temp_file}"
  while IFS= read -r line; do
    echo "    ${line}" >>"${temp_file}"
  done <<<"${input_content}"

  sed -i "${end_line}r ${temp_file}" "${target_file}"
  rm -f "${temp_file}"
  trap - EXIT

  info "==> Comment added to task"
}

add_task() {
  local input_content
  read_input_content

  input_content=$(echo "${input_content}" | sed -e '1s/- \[ \] //' -e '1s/- //' -e "1s/^/- [ ] $(get_timestamp_prefix) /")

  if [[ -s ${target_file} ]] && [[ -n $(tail -c1 "${target_file}") ]]; then
    printf '\n' >>"${target_file}"
  fi
  printf '%s\n' "${input_content}" >>"${target_file}"

  info "==> Task added"
}

summary_task() {
  task_dir_name=$(basename "$git_root")
  # front matter の title を概要として表示
  local title task_summary
  title=$(front_matter_value "$target_file" title)
  task_summary=
  [[ -n $title ]] && task_summary=" [${title}]"
  echo "$task_dir_name$task_summary"
}

# branch に対応する既存 worktree の絶対パスを返す (無ければ空)。
# パス命名規約を自前で持たず git を SSOT にする (git_worktree との二重定義回避)。
existing_worktree_for() {
  local branch="$1"
  git -C "$git_root" worktree list --porcelain 2>/dev/null |
    awk -v b="refs/heads/$branch" '
      /^worktree /{wt=substr($0, 10)}
      /^branch /{if ($2 == b) {print wt; exit}}' || :
}

# branch の worktree を保証する。既存なら作成を skip し、無ければ git_worktree で作成。
# worktree 内 .tasks.md => index_md / .tasks => base の link も張る (冪等)。
# split / spawn 共用。結果の worktree 絶対パスをグローバル worktree_dir にセットする。
ensure_worktree() {
  local branch="$1" index_md="$2" wt base_dir
  wt=$(existing_worktree_for "$branch")
  if [[ -n $wt ]]; then
    info "==> Worktree already exists, skip creation: $wt"
  fi
  if [[ -z $wt ]]; then
    wt=$(git_worktree -a "$branch") ||
      die "==> Failed to create worktree for: $branch"
    [[ -n $wt && -e $wt ]] ||
      die "==> Failed to create worktree for: $branch"
  fi
  base_dir=$(realpath "$git_root/.tasks")
  # dangling symlink でも -L で検出し _ln の二重作成失敗を防ぐ
  [[ -e "$wt/.tasks.md" || -L "$wt/.tasks.md" ]] || _ln "$index_md" "$wt/.tasks.md"
  [[ -e "$wt/.tasks" || -L "$wt/.tasks" ]] || _ln "$base_dir" "$wt/.tasks"
  worktree_dir="$wt"
}

# split 済み参照行・未 split タスクから worktree + tmux + CC /task を起動する
spawn_task() {
  local candidates selected
  # 未 split 含む全 pending タスクが対象 (skip_refs=0)
  candidates=$(list_task_lines 0 0)
  [[ -n $candidates ]] || die "==> No tasks to spawn in $target_file"
  selected=$(choose_lines "$candidates" "Select task(s) to spawn: ") || true
  [[ -n $selected ]] || die "==> No task selected."
  process_selected "$selected" spawn_one
}

# 指定行の pending タスクを spawn する。
# 参照行(split 済み): index.md を解決し worktree を保証してから tmux 起動。
# 未 split タスク: split (index.md + worktree) してから tmux 起動。
spawn_one() {
  local line_no="$1" line is_ref ref_path index_md branch worktree_name session repo_name
  line=$(sed -n "${line_no}p" "$target_file")
  is_ref=0
  if printf '%s\n' "$line" | grep -qE "$grep_key_reference"; then
    is_ref=1
  fi

  if [[ $is_ref -eq 0 ]]; then
    split_one_task "$line_no"
    branch="$task_branch"
  fi
  if [[ $is_ref -eq 1 ]]; then
    ref_path=$(from_reference_line "$line")
    # ref_path は store_root 相対なので絶対パスへ解決する
    index_md="$store_root/$ref_path"
    [[ -e $index_md ]] || die "==> Reference index not found: $index_md"
    branch=$(front_matter_value "$index_md" branch)
    [[ -n $branch ]] || die "==> No 'branch' in front matter: $index_md"
    ensure_worktree "$branch" "$index_md"
  fi

  # tmux セッション作成 + agent (claude/codex) で task 起動 (worktree_dir は ensure_worktree がセット)
  # repo 名は worktree でも親リポを指すよう git-common-dir から逆引きする
  repo_name=$(basename "$(dirname "$(git -C "$git_root" rev-parse --path-format=absolute --git-common-dir)")")
  worktree_name=${branch//\//-}
  # tmux のセッション名は '.'/':' を含められないので英数_-以外を - に置換 (先頭 - は除去)
  session="${repo_name}-${worktree_name}"
  session=${session//[^A-Za-z0-9_-]/-}
  session=${session#-}
  spawn_tmux_session "$session" "$worktree_dir"
  info "==> Spawned worktree: $worktree_dir"
  info "==> tmux session: $session"
}

spawn_tmux_session() {
  local session="$1" dir="$2" cmd
  if tmux has-session -t "$session" 2>/dev/null; then
    warn "==> tmux session already exists: $session"
    return 0
  fi
  # claude は skill を '/task'、codex は '$task' で起動する (codex の skill 参照は '$' prefix)。
  # codex はシングルクォートで囲み、対話シェルによる $task 展開を防ぐ (literal を codex へ渡す)。
  case "$spawn_agent" in
    codex) cmd="codex '\$task'" ;;
    *) cmd='claude "/task"' ;;
  esac
  tmux new-session -d -s "$session" -c "$dir"
  tmux send-keys -t "$session" "$cmd" Enter
}

resolve_target() {
  if [[ -n $task_file ]]; then
    # -f で taskfile を直接指定。git_root はそのファイルの親dirから導出する
    git_root=$(cd "$(dirname "$task_file")" && pwd) || exit 1
    target_file="$git_root/$(basename "$task_file")"
    return
  fi
  # git_rootはworktree内にいる場合はそのworktreeのルートを指す
  git_root=$(git rev-parse --show-toplevel)
  target_file="$git_root/.tasks.md"
}

main() {
  initialize "$@"

  resolve_target
  cd "$git_root" || exit 1

  # config は全モード共通の前提。ここで1回だけ読み込み fail-fast 検証する。
  load_tasks_config

  # .tasks.md(ファイル) と .tasks(ディレクトリ) のリンクが無ければ生成（遅延初期化）
  # preview は親 fzf からの読み取り専用再呼び出しなので link 初期化は不要 (skip)。
  if [[ $mode != preview && $(basename "$target_file") == ".tasks.md" ]]; then
    initialize_links_if_needed
  fi
  [[ -e $target_file ]] || die "==> Task file not found: $target_file"
  # NOTE: fix sed -i overwrite symlink and break link, so use realpath
  target_file=$(realpath "$target_file")

  case $mode in
    next) cat_first_task ;;
    split) split_task ;;
    clean) clean_tasks ;;
    comment) comment_task ;;
    add) add_task ;;
    complete) complete_task ;;
    spawn) spawn_task ;;
    summary) summary_task ;;
    preview) preview_line "$task_index" ;;
    *) find_tasks | v ;;
  esac
}
main "$@"
