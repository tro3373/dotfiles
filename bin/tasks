#!/usr/bin/env bash

readonly depends=(curl fzf jq)
timestamp=$(date +%Y%m%d-%H%M%S) && readonly timestamp
command_name=$(basename "$0") && readonly command_name
worktree_dir_name="-worktree" && readonly worktree_dir_name
grep_key_task_exists='- \[ \]' && readonly grep_key_task_exists
grep_key_task_completed='- \[[xX]\]' && readonly grep_key_task_completed
args=()
mode=list
target_dir=
comment_type=
comment_file=
task_index=1

usage() {
  cat <<EOF

Manage repository tasks.

  Usage:
      $command_name [option]
    Options
      -h|--help           : Show this usage
      -d|--directory      : Show task directory
      -s|--split          : Split tasks into multiple files
      -sa|--split-all     : Split all tasks into multiple files
      -n|--next [N]       : Show next task chunk (N=1..: Nth task, default 1)
                            Also: -nN, --next=N
      -c|--clean          : Move completed tasks to .tasks/done/done.md
      ok|v|done|complete  : Mark next task chunk as completed
      -m|--comment [type] : Add comment to first task (type: requirement|review|complete)
      -a|--add            : Add task from stdin or file (prepends "- [ ] " if missing)
      -f|--file [path]    : Specify file to read content from (use with -m or -a)
      --summary           : Show title of tasks
EOF
}

initialize() {
  while true; do
    [[ -z $1 ]] && break
    case "$1" in
      -h | --help) usage && exit 0 ;;
      -d | --directory) shift && target_dir=$1 ;;
      -s | --split) mode="split" ;;
      -sa | --split-all) mode="split-all" ;;
      -n | --next)
        mode="next"
        if [[ ${2:-} =~ ^[0-9]+$ ]]; then
          shift && task_index=$1
        fi
        ;;
      -n[0-9]*)
        mode="next"
        task_index=${1#-n}
        [[ $task_index =~ ^[1-9][0-9]*$ ]] || error "==> Invalid option: $1"
        ;;
      --next=*)
        mode="next"
        task_index=${1#--next=}
        [[ $task_index =~ ^[1-9][0-9]*$ ]] || error "==> Invalid option: $1"
        ;;
      -c | --clean) mode="clean" ;;
      -m | --comment)
        if [[ -z ${2:-} ]]; then
          error "==> -m|--comment requires a type argument: requirement|review|complete"
        fi
        shift && comment_type=$1 && mode="comment"
        ;;
      -a | --add) mode="add" ;;
      -f | --file) shift && comment_file=$1 ;;
      ok | v | done | complete) mode="complete" ;;
      --summary) mode="summary" ;;
      *) add_args "$1" ;;
    esac
    shift
  done
  check
  set -euo pipefail
}
check() { hass "${depends[@]}"; }
add_args() { args+=("$@"); }
has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || error "==> No $arg command exist."; done; }
_ink() { cat - | if has ink; then ink "$@"; else cat -; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
error() { _log red "$*" && exit 1; }
current_is_worktree_dir() { [[ $git_root =~ ^.*${worktree_dir_name}/.*$ ]]; }

initialize_links_if_needed() {
  dst_tasks_md="$git_root/.tasks.md"
  dst_tasks_dir="$git_root/.tasks"
  [[ -e $dst_tasks_md && -e $dst_tasks_dir ]] && return

  info "==> Initialize tasks files.."
  repo_name=$(basename "$git_root")
  suffix="tasks"
  if current_is_worktree_dir; then
    worktree_root_name=$(basename "$(dirname "$git_root")")
    repo_name=${worktree_root_name%"$worktree_dir_name"}
    worktree_name=$(basename "$git_root")
    suffix="${worktree_name}_tasks"
  fi
  tasks_dir="$HOME/.mo/tasks/$repo_name"
  tasks_md="$(find "$tasks_dir/" -type f -name "*_${suffix}.md" | sort | tail -1 || :)"
  if [[ -z $tasks_md ]]; then
    tasks_md="$tasks_dir/${timestamp}_${suffix}.md"
  fi
  if [[ ! -e $dst_tasks_dir ]]; then
    mkdir -p "$tasks_dir/done"
    _ln "$tasks_dir" "$dst_tasks_dir"
  fi
  if [[ ! -e $dst_tasks_md ]]; then
    touch "$tasks_md"
    _ln "$tasks_md" "$dst_tasks_md"
  fi
}

_ln() {
  info "==> Linking $1 to $2"
  ln -s "$1" "$2"
}

find_tasks() {
  echo .tasks.md
  rg --files .tasks/ | sort
}

cat_first_task() {
  # awk '
  #   /^- / {
  #     if (in_task) {
  #       exit
  #     }
  #   }
  #   /^- \[ \]/ {
  #     in_task = 1
  #     print
  #     next
  #   }
  #   {
  #     if (in_task) {
  #       print
  #     }
  #   }
  # ' "$target_file"
  # parse_first_task
  parse_tasks 0 "$task_index"
  sed -n "${first_line},${end_line}p" "$target_file"
}

# parse_first_task() {
#   if [[ ! -s $target_file ]] || ! grep -qE '^- \[ \]' "$target_file"; then
#     error "==> Empty tasks. $target_file"
#   fi

#   # ŃāüŃé¦ŃāāŃé»Ńā£ŃāāŃé»Ńé╣ĶĪīŃü«ĶĪīńĢ¬ÕÅĘŃéÆÕÅ¢ÕŠŚ
#   line_numbers=$(grep -nE '^- \[ \]' "$target_file" | cut -d: -f1)

#   # µ£ĆÕłØŃü«ĶĪīńĢ¬ÕÅĘŃéÆÕÅ¢ÕŠŚ
#   first_line=$(echo "$line_numbers" | head -n1)

#   # 2ńĢ¬ńø«Ńü«ĶĪīńĢ¬ÕÅĘŃéÆÕÅ¢ÕŠŚ’╝łŃü¬ŃüæŃéīŃü░ŃāĢŃéĪŃéżŃā½µ£½Õ░Š’╝ē
#   second_line=$(echo "$line_numbers" | sed -n '2p')
#   if [[ -z $second_line ]]; then
#     second_line=$(($(wc -l <"$target_file") + 1))
#   fi

#   # ń»äÕø▓ŃéÆĶ©łń«Ś’╝ł2ńĢ¬ńø«Ńü«ńø┤ÕēŹŃüŠŃü¦’╝ē
#   end_line=$((second_line - 1))
# }

parse_tasks() {
  comp=$1
  local index=${2:-1}
  grep_key=$grep_key_task_exists
  [[ $comp -eq 1 ]] && grep_key=$grep_key_task_completed
  if [[ ! -s $target_file ]] || ! grep -qE "^$grep_key" "$target_file"; then
    error "==> Empty tasks."
  fi

  # NńĢ¬ńø«Ńü«Ńé┐Ńé╣Ńé»ĶĪīŃéÆÕÅ¢ÕŠŚ
  first_line=$(grep -nE "^$grep_key" "$target_file" | sed -n "${index}p" | cut -d: -f1)
  if [[ -z $first_line ]]; then
    error "==> Task index ${index} not found."
  fi

  # first_line õ╗źķÖŹŃü«µ¼ĪŃü« `- ` ĶĪīŃéÆÕÅ¢ÕŠŚ’╝łŃé┐Ńé╣Ńé»Ńü«ńĄéń½»’╝ē
  second_line=$(grep -nE '^- ' "$target_file" | awk -F: -v fl="$first_line" '$1 > fl {print $1; exit}')

  # 2ńĢ¬ńø«Ńü«ĶĪīńĢ¬ÕÅĘŃüīŃü¬ŃüæŃéīŃü░ŃāĢŃéĪŃéżŃā½µ£½Õ░Š
  if [[ -z $second_line ]]; then
    second_line=$(($(wc -l <"$target_file") + 1))
  fi

  # ń»äÕø▓ŃéÆĶ©łń«Ś’╝ł2ńĢ¬ńø«Ńü«ńø┤ÕēŹŃüŠŃü¦’╝ē
  end_line=$((second_line - 1))
}

split_tasks() {
  # tempŃāĢŃéĪŃéżŃā½Ńü½µŖĮÕć║
  local temp_file
  temp_file=$(mktemp)
  cat_first_task >"$temp_file"

  # ÕģāŃāĢŃéĪŃéżŃā½ŃüŗŃéēÕēŖķÖż
  sed -i "${first_line},${end_line}d" "$target_file"

  # prpŃé│Ńā×Ńā│ŃāēŃü¦JSONÕÅ¢ÕŠŚ
  local json_result
  json_result=$(cat "$temp_file" | prp -ne gen-task-title-and-branch.md$ | llm -c tgpt -p groq)

  # JSONĶ¦Żµ×É
  local branch name title
  branch=$(echo "$json_result" | jq -r '.branch')
  name=$(echo "$json_result" | jq -r '.name')
  title=$(echo "$json_result" | jq -r '.title')

  # Ńé┐Ńé╣Ńé»ŃāĢŃéĪŃéżŃā½õĮ£µłÉ
  worktree_name=${branch/\//-}
  local task_file=".tasks/${timestamp}_${worktree_name}_${name}.md"
  # NOTE: git_worktree -a Ńü¦ link ŃüŠŃü¦Ķ▓╝ŃéēŃéīŃéŗŃü«Ńü¦ŃĆüõ║ŗÕēŹŃü½ŃāĢŃéĪŃéżŃā½õĮ£µłÉŃüŚŃü”ŃüŖŃüÅ
  touch "$task_file"

  # worktree Ńā¢Ńā®Ńā│ŃāüõĮ£µłÉ
  local worktree_dir
  worktree_dir=$(git_worktree -a "${branch}")

  # Ńā×Ńā╝Ńé»ŃāĆŃé”Ńā│ÕĮóÕ╝ÅŃü¦ŃāĢŃéĪŃéżŃā½õĮ£µłÉ
  cat >"$task_file" <<EOF
## ${title}
### Ńā¢Ńā®Ńā│ŃāüÕÉŹ
- ${branch}
### õĮ£µźŁŃāćŃéŻŃā¼Ńé»ŃāłŃā¬
- ${worktree_dir}
### Ńé┐Ńé╣Ńé»ÕåģÕ«╣
$(cat "$temp_file")
EOF

  # link task_file
  _ln "$(realpath "$git_root/$task_file")" "$worktree_dir/.tasks.md"
  if [[ ! -e "$worktree_dir/.tasks" ]]; then
    _ln "$(realpath "$git_root/.tasks")" "$worktree_dir/.tasks"
  fi

  # tempŃāĢŃéĪŃéżŃā½ÕēŖķÖż
  rm -f "$temp_file"

  info "==> Task split to: $task_file"
  info "==> Branch: $branch"
}

split_tasks_all() {
  split_tasks
  # ŃüŠŃüĀŃé┐Ńé╣Ńé»Ńüīµ«ŗŃüŻŃü”ŃüäŃéīŃü░ÕåŹÕĖ░ńÜäŃü½Õć”ńÉå
  if has_tasks; then
    split_tasks_all
  fi
}

has_tasks() {
  grep -qE "^$grep_key_task_exists" "$target_file"
}

has_completed_tasks() {
  grep -qE "^$grep_key_task_completed" "$target_file"
}

clean_tasks() {
  trap 'info "==> Task cleaned"' EXIT
  if current_is_worktree_dir; then
    clean_worktree_tasks
    return
  fi
  clean_normal_tasks
}

clean_worktree_tasks() {
  real_task_file=$(realpath "$git_root/.tasks.md")
  real_done_dir=$(realpath "$git_root/.tasks/done")
  if [[ ! -e $real_task_file ]] || [[ ! -e $real_done_dir ]]; then
    error "==> Invalid state. real_task_file=$real_task_file, real_done_dir=$real_done_dir"
  fi
  # TODO dst is exist
  info "==> Moving $real_task_file to $real_done_dir/"
  mv -v "$real_task_file" "$real_done_dir/"
  worktree_name=$(basename "$git_root")
  find "$git_root/.tasks/" -maxdepth 1 -mindepth 1 -type f -name "*_${worktree_name}_*.md" -exec mv -v {} "$git_root/.tasks/done/" \;
}

clean_normal_tasks() {
  has_completed_tasks || return 0
  ymd=$(date +%Y%m%d)
  local done_file="$git_root/.tasks/done/${ymd}_done.md"
  echo "## $timestamp" | tee -a "$done_file"
  clean_normal_tasks_recursive
}

clean_normal_tasks_recursive() {
  parse_tasks 1
  sed -n "${first_line},${end_line}p" "$target_file" |
    tee -a "$done_file"
  # ÕģāŃāĢŃéĪŃéżŃā½ŃüŗŃéēÕēŖķÖż
  sed -i "${first_line},${end_line}d" "$target_file"
  # ŃüŠŃüĀŃé┐Ńé╣Ńé»Ńüīµ«ŗŃüŻŃü”ŃüäŃéīŃü░ÕåŹÕĖ░ńÜäŃü½Õć”ńÉå
  has_completed_tasks || return 0
  clean_normal_tasks_recursive
}

complete_task() {
  local complete_mark="Ō£ģ’ĖÅ"
  first_line=$(head -1 "$target_file")
  if [[ $first_line =~ ^#+\ (.*)$ ]]; then
    if ! has_tasks; then
      complete_title_task
      return
    fi
  fi
  complete_normal_task
}

complete_title_task() {
  completed=0
  if echo "$first_line" | grep -qE $complete_mark; then
    warn "==> Task already marked as completed."
    completed=1
  fi
  if [[ $completed -eq 0 ]]; then
    sed -i "1s/^## \(.*\)$/## $complete_mark \1/" "$target_file"
    info "==> $complete_mark Task title marked as completed"
  fi
  # show target task title
  sed -n "1p" "$target_file"
}

complete_normal_task() {
  # Ńü»ŃüśŃéüŃü½Ķ”ŗŃüżŃüŗŃéŗŃé┐Ńé╣Ńé»ŃéÆÕ«īõ║åŃü½ŃüÖŃéŗ
  parse_tasks 0
  # Ńé┐Ńé╣Ńé»ŃéÆÕ«īõ║åŃü½ŃüÖŃéŗ
  sed -i "${first_line}s/^- \[ \]/- [x]/" "$target_file"
  info "==> $complete_mark Task marked as completed"
  sed -n "${first_line}p" "$target_file"
}

get_comment_header() {
  case "${comment_type}" in
    requirement) echo "­¤ÄŁ Ķ”üõ╗Č(ŃüĄŃéŗŃüŠŃüä)" ;;
    review) echo "­¤æŹ Ńā¼ŃāōŃāźŃā╝õ┐«µŁŻ" ;;
    complete) echo "Ō£ģ Õ«īõ║å" ;;
    *) error "==> Invalid comment type: ${comment_type}. Use: requirement|review|complete" ;;
  esac
}

read_input_content() {
  input_content=
  if [[ -n ${comment_file} ]]; then
    if [[ ! -f ${comment_file} ]]; then
      error "==> File not found: ${comment_file}"
    fi
    input_content=$(cat "${comment_file}")
  fi

  if [[ -z ${input_content} ]]; then
    if [[ -t 0 ]]; then
      error "==> No input from stdin."
    fi
    input_content=$(cat)
  fi

  if [[ -z ${input_content} ]]; then
    error "==> Empty input."
  fi
}

comment_task() {
  local header input_content
  header=$(get_comment_header)

  read_input_content

  parse_tasks 0

  local temp_file
  temp_file=$(mktemp)
  trap 'rm -f "${temp_file}"' EXIT

  echo "  - ${header}" >"${temp_file}"
  while IFS= read -r line; do
    echo "    ${line}" >>"${temp_file}"
  done <<<"${input_content}"

  sed -i "${end_line}r ${temp_file}" "${target_file}"
  rm -f "${temp_file}"
  trap - EXIT

  info "==> Comment added to task"
}

add_task() {
  local input_content first_input_line
  read_input_content

  first_input_line=$(printf '%s\n' "${input_content}" | head -n1)
  if [[ ! ${first_input_line} =~ ^-\ \[\ \] ]]; then
    input_content="- [ ] ${input_content}"
  fi

  if [[ -s ${target_file} ]] && [[ -n $(tail -c1 "${target_file}") ]]; then
    printf '\n' >>"${target_file}"
  fi
  printf '%s\n' "${input_content}" >>"${target_file}"

  info "==> Task added"
}

summary_tasks() {
  task_dir_name=$(basename "$git_root")
  # Ńé┐Ńé╣Ńé»Ńü«µ”éĶ”üŃéÆµŖĮÕć║ŃüŚŃü”ĶĪ©ńż║
  first_line=$(head -1 "$target_file")
  task_summary=
  if [[ -n $first_line && $first_line =~ ^(#)+\ .*$ ]]; then
    task_summary=" [${first_line##*# }]"
  fi
  echo "$task_dir_name$task_summary"
}

main() {
  initialize "$@"

  git_root="$target_dir"
  if [[ -z $git_root ]]; then
    # git_rootŃü»worktreeÕåģŃü½ŃüäŃéŗÕĀ┤ÕÉłŃü»ŃüØŃü«worktreeŃü«Ńā½Ńā╝ŃāłŃéÆµīćŃüÖ
    git_root=$(git rev-parse --show-toplevel)
  fi
  cd "$git_root" || exit 1

  target_file="$git_root/.tasks.md"
  initialize_links_if_needed
  # NOTE: fix sed -i overwrite symlink and break link, so use realpath
  target_file=$(realpath "$target_file")

  if [[ $mode == "next" ]]; then
    cat_first_task
    return
  fi
  if [[ $mode == "split" ]]; then
    split_tasks
    return
  fi
  if [[ $mode == "split-all" ]]; then
    split_tasks_all
    return
  fi
  if [[ $mode == "clean" ]]; then
    clean_tasks
    return
  fi
  if [[ ${mode} == "comment" ]]; then
    comment_task
    return
  fi
  if [[ ${mode} == "add" ]]; then
    add_task
    return
  fi
  if [[ $mode == "complete" ]]; then
    complete_task
    return
  fi
  if [[ $mode == "summary" ]]; then
    summary_tasks
    return
  fi

  find_tasks | v
}
main "$@"
