#!/usr/bin/env bash
# test: bin/lib/test/tasks
# ~/.config/tasks/config.env

readonly depends=(curl fzf jq tmux git_worktree)
readonly timestamp_fmt="+%Y%m%d-%H%M%S"
timestamp=$(date $timestamp_fmt) && readonly timestamp
command_name=$(basename "$0") && readonly command_name
grep_key_task_exists='- \[ \]' && readonly grep_key_task_exists
grep_key_task_completed='- \[[xX]\]' && readonly grep_key_task_completed
# 参照行 (split 済みタスクへのリンク): `- [ ] [title](store_root相対path)` 形式
grep_key_reference='^- \[[ xX]\] \[[^]]*\]\(' && readonly grep_key_reference
# 完了済み参照行のみ (clean 対象): `- [x] [title](path)`
grep_key_reference_done='^- \[[xX]\] \[[^]]*\]\(' && readonly grep_key_reference_done
args=()
mode=list
comment_type=
task_file=
task_index=
task_index_explicit=0
parse_skip_refs=0
# config (load_tasks_config が設定): store_root=絶対, tasks_subdir=相対, log_fmt=相対フォーマット
store_root=
tasks_subdir=
log_fmt=
tasks_store_dir=

usage() {
  cat <<EOF

Manage repository tasks.

  Usage:
      $command_name [option] [N]
    Options
      -h|--help           : Show this usage
      -s|--split          : Split Nth task into a task directory (default 1)
      -sa|--split-all     : Split all tasks into task directories
      -n|--next           : Show Nth task chunk (default 1; also -n2, --next=2)
      -c|--clean          : Record completed split references to log and drop from list
      ok|v|done|complete  : Mark Nth task chunk as completed (default 1)
      -m|--comment [type] : Add comment to Nth task (type: requirement|review|complete)
      -a|--add            : Add task from stdin (prepends "- [ ] " if missing)
      -f|--file [path]    : Specify task file to operate on (default: repo .tasks.md)
      spawn|--spawn       : Spawn worktree + tmux + CC /task from a split reference
      --summary           : Show title of tasks
    Task index [N]
      Selects the Nth pending task (1-based, default 1) for
      next/split/comment/complete/spawn. Give as a bare number or -N (e.g. 2, -2).
EOF
}

initialize() {
  while true; do
    [[ -z $1 ]] && break
    case "$1" in
      -h | --help) usage && exit 0 ;;
      -s | --split) mode="split" ;;
      -sa | --split-all) mode="split-all" ;;
      -n | --next)
        mode="next"
        if [[ ${2:-} =~ ^[0-9]+$ ]]; then
          shift && task_index=$1
        fi
        ;;
      -n[0-9]*)
        mode="next"
        task_index=${1#-n}
        [[ $task_index =~ ^[1-9][0-9]*$ ]] || die "==> Invalid option: $1"
        ;;
      --next=*)
        mode="next"
        task_index=${1#--next=}
        [[ $task_index =~ ^[1-9][0-9]*$ ]] || die "==> Invalid option: $1"
        ;;
      -c | --clean) mode="clean" ;;
      -m | --comment)
        if [[ -z ${2:-} ]]; then
          die "==> -m|--comment requires a type argument: requirement|review|complete"
        fi
        shift && comment_type=$1 && mode="comment"
        ;;
      -a | --add) mode="add" ;;
      -f | --file)
        if [[ -z ${2:-} ]]; then
          die "==> -f|--file requires a path argument"
        fi
        shift && task_file=$1
        ;;
      ok | v | done | complete) mode="complete" ;;
      spawn | --spawn) mode="spawn" ;;
      --summary) mode="summary" ;;
      -[0-9]*)
        task_index=${1#-}
        [[ $task_index =~ ^[1-9][0-9]*$ ]] || die "==> Invalid option: $1"
        ;;
      [0-9]*)
        [[ $1 =~ ^[1-9][0-9]*$ ]] || die "==> Invalid index: $1"
        task_index=$1
        ;;
      *) add_args "$1" ;;
    esac
    shift
  done
  [[ -n $task_index ]] && task_index_explicit=1
  check
  set -euo pipefail
}
check() {
  hass "${depends[@]}"
  if [[ -z $task_file ]]; then
    git rev-parse --is-inside-work-tree &>/dev/null || die "==> Not inside a git worktree."
  fi
}
add_args() { args+=("$@"); }
has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || die "==> No $arg command exist."; done; }
_ink() { cat - | if has ink; then ink "$@"; else cat -; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
die() { _log red "$*" && exit 1; }
# linked worktree では git-common-dir(共有 .git) と git-dir(worktree 個別) が食い違う。
# パス命名規約に依存しない判定 (git_worktree の is_invoked_from_worktree と同方式)。
current_is_worktree_dir() {
  local common gitdir
  common=$(git -C "$git_root" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  gitdir=$(git -C "$git_root" rev-parse --path-format=absolute --git-dir 2>/dev/null) || return 1
  [[ $common != "$gitdir" ]]
}
get_timestamp_prefix() { date +"[%Y%m%d_%H%M%S]"; }
# 絶対パスの先頭 $HOME を ~ に畳む / ~ を $HOME に展開する。
# 参照や parent をユーザ名非依存の ~ 形式で保存し、利用時に展開する。
to_tilde() { printf '%s' "${1/#$HOME/\~}"; }
from_tilde() { printf '%s' "${1/#\~/$HOME}"; }
# 参照行 `- [ ] [title](path)` とパスの相互変換 (to_tilde/from_tilde と同様の対)。
# title は path のタスクディレクトリ名 (basename of dirname) を SSOT として導出。
# from は完了状態 `- [x] [title](path)` のパスも取り出せる。
to_reference_line() {
  local path="$1" title
  title=$(basename "$(dirname "$path")")
  printf '%s' "- [ ] [$title]($path)"
}
from_reference_line() { sed -E 's/^- \[[ xX]\] \[[^]]*\]\((.*)\)$/\1/' <<<"$1"; }

# log_fmt の strftime 指定子 (%Y, %Y-%m 等) を date で実値化する。
expand_log_fmt() { date +"$1"; }

# YAML front matter を出力 (title, branch, name, parent)。done は常に false。
# body は呼び出し側で追記する。front matter スキーマの SSOT。
emit_front_matter() {
  local title="$1" branch="$2" name="$3" parent="$4"
  printf '%s\n' '---'
  printf 'title: %s\n' "$title"
  printf 'branch: %s\n' "$branch"
  printf 'name: %s\n' "$name"
  printf 'done: false\n'
  printf 'parent: %s\n' "$parent"
  printf '%s\n' '---'
  printf '\n'
}

# .tasks.md(file) と .tasks(dir) のリンクが無ければ生成。
# not worktree: {tasks_subdir}/{repo}/index.md を生成し .tasks.md => index.md
# worktree    : 親リポと共有 base を使い worktree 専用 .tasks.md を自己修復
initialize_links_if_needed() {
  dst_tasks_md="$git_root/.tasks.md"
  dst_tasks_dir="$git_root/.tasks"
  [[ -e $dst_tasks_md && -e $dst_tasks_dir ]] && return

  if current_is_worktree_dir; then
    initialize_worktree_links
    return
  fi
  initialize_normal_links
}

initialize_normal_links() {
  info "==> Initialize tasks files.."
  local repo_name repo_tasks_dir repo_tasks_md
  repo_name=$(basename "$git_root")
  repo_tasks_dir="$tasks_store_dir/$repo_name"
  repo_tasks_md="$repo_tasks_dir/index.md"
  if [[ ! -e $dst_tasks_dir ]]; then
    mkdir -p "$repo_tasks_dir"
    _ln "$repo_tasks_dir" "$dst_tasks_dir"
  fi
  if [[ ! -e $dst_tasks_md ]]; then
    touch "$repo_tasks_md"
    _ln "$repo_tasks_md" "$dst_tasks_md"
  fi
}

# worktree のリンクを自己修復する。親リポを git-common-dir から逆引きし
# {tasks_subdir}/{repo} を親と共有する base として使う。worktree のブランチは
# 確定済みなので LLM 推論なしで split と同型の front matter を決定的に生成する。
initialize_worktree_links() {
  info "==> Initialize worktree tasks files.."
  local org_root repo_name base_dir branch name wt_ts wt_md wt_dir
  org_root=$(dirname "$(git -C "$git_root" rev-parse --path-format=absolute --git-common-dir)")
  repo_name=$(basename "$org_root")
  base_dir="$tasks_store_dir/$repo_name"
  mkdir -p "$base_dir"

  branch=$(git -C "$git_root" rev-parse --abbrev-ref HEAD)
  [[ -z $branch || $branch == "HEAD" ]] && branch=$(basename "$git_root")
  name=${branch//\//-}
  wt_ts=$(date -r "$git_root" $timestamp_fmt)
  wt_dir="$base_dir/${wt_ts}_${name}"
  mkdir -p "$wt_dir"
  wt_md="$wt_dir/index.md"
  [[ -e $wt_md ]] ||
    emit_front_matter "$branch" "$branch" "$name" "$(to_tilde "$org_root/.tasks.md")" >"$wt_md"
  [[ -e $dst_tasks_dir ]] || _ln "$base_dir" "$dst_tasks_dir"
  [[ -e $dst_tasks_md ]] || _ln "$wt_md" "$dst_tasks_md"
}

# config から store_root/tasks_subdir/log_fmt を読み込む。SSOT は config。
# tasks_store_dir = store_root/tasks_subdir。main から全モード共通で1回だけ呼ぶ。
# log_fmt は strftime 指定子を含むパスフォーマット (ex: log_fmt=logs/%Y/%Y-%m-01-log.md)。
load_tasks_config() {
  local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/tasks/config.env"
  [[ -f $config_file ]] ||
    die "==> No config: $config_file => Define store_root, tasks_subdir, log_fmt"
  # shellcheck source=/dev/null
  source "$config_file" ||
    die "==> Failed to load config (syntax error?): $config_file"
  [[ -n ${store_root:-} ]] || die "==> 'store_root' is not set in $config_file"
  [[ -n ${tasks_subdir:-} ]] || die "==> 'tasks_subdir' is not set in $config_file"
  [[ -n ${log_fmt:-} ]] || die "==> 'log_fmt' is not set in $config_file"
  store_root=$(from_tilde "$store_root")
  [[ $store_root == /* ]] ||
    die "==> 'store_root' must be an absolute path: $store_root"
  store_root=$(realpath -m "$store_root")
  tasks_store_dir="$store_root/$tasks_subdir"
}

_ln() {
  info "==> Linking $1 to $2"
  ln -s "$1" "$2"
}

find_tasks() {
  echo .tasks.md
  find .tasks/ -maxdepth 1 -mindepth 1 -type f -name '*.md' 2>/dev/null | sort -nr || :
}

cat_first_task() {
  parse_tasks 0 "$task_index"
  sed -n "${first_line},${end_line}p" "$target_file"
}

parse_tasks() {
  comp=$1
  local index=${2:-1}
  grep_key=$grep_key_task_exists
  [[ $comp -eq 1 ]] && grep_key=$grep_key_task_completed
  if [[ ! -s $target_file ]] || ! grep -qE "^$grep_key" "$target_file"; then
    die "==> Empty tasks."
  fi

  # N番目のタスク行を取得。split 時は参照行 (- [ ](...)) を候補から除外する
  local lines
  lines=$(grep -nE "^$grep_key" "$target_file")
  if [[ $parse_skip_refs -eq 1 ]]; then
    lines=$(printf '%s\n' "$lines" | { grep -vE "^[0-9]+:${grep_key_reference#^}" || :; })
  fi
  first_line=$(printf '%s\n' "$lines" | sed -n "${index}p" | cut -d: -f1)
  if [[ -z $first_line ]]; then
    die "==> Task index ${index} not found."
  fi

  # first_line 以降の次の `- ` 行 or 見出し行(#) を取得（タスクの終端）
  second_line=$(grep -nE '^(- |#)' "$target_file" | awk -F: -v fl="$first_line" '$1 > fl {print $1; exit}')

  # 2番目の行番号がなければファイル末尾
  if [[ -z $second_line ]]; then
    second_line=$(($(wc -l <"$target_file") + 1))
  fi

  # 範囲を計算（2番目の直前まで）
  end_line=$((second_line - 1))
}

# タスク内容(stdin)から branch/name/title の JSON を生成する。
# テスト用に TASKS_GEN_META_CMD で生成コマンドを差し替え可能 (stdin を読み JSON を出力)。
gen_task_meta() {
  if [[ -n ${TASKS_GEN_META_CMD:-} ]]; then
    "${TASKS_GEN_META_CMD}"
    return
  fi
  prp -ne 'gen-task-title-and-branch.md$' | llm -c tgpt -p groq -fc claude
}

split_task() {
  local tmp_file json_result branch name title
  local base_dir task_dir task_index_md parent_md ref

  parse_skip_refs=1

  # NOTE: cat_first_task で first_line/end_line をセットしている
  # sub processでは変数にセットされないので、ファイル出力している
  tmp_file=$(mktemp)
  cat_first_task >"$tmp_file"
  json_result=$(gen_task_meta <"$tmp_file")

  branch=$(echo "$json_result" | jq -r '.branch')
  name=$(echo "$json_result" | jq -r '.name')
  title=$(echo "$json_result" | jq -r '.title')
  if [[ -z $branch || -z $name || -z $title || $branch == null ]]; then
    die "==> Invalid task meta JSON: $json_result"
  fi

  # タスクディレクトリ: {tasks_subdir}/{repo}/{timestamp}_{name}/index.md
  # .tasks は {tasks_subdir}/{repo} を指す symlink
  base_dir=$(realpath "$git_root/.tasks")
  task_dir="$base_dir/${timestamp}_${name}"
  mkdir -p "$task_dir"
  task_index_md="$task_dir/index.md"
  parent_md=$(to_tilde "$(realpath "$git_root/.tasks.md")")

  # YAML front matter + タスク内容
  {
    emit_front_matter "$title" "$branch" "$name" "$parent_md"
    cat "$tmp_file"
  } >"$task_index_md"

  # 元リストの当該タスクを参照行へ置換 (削除しない)。ref は store_root 相対パス。
  ref=${task_index_md#"$store_root"/}
  [[ $ref != /* ]] ||
    die "==> Task path not under store_root: $task_index_md (store_root=$store_root)"
  replace_task_with_reference "$ref"

  rm -f "$tmp_file"
  info "==> Task split to: $task_index_md"
  info "==> Branch: $branch"
}

# first_line..end_line のタスクブロックを 1 行の参照リンクに置換する
replace_task_with_reference() {
  local ref="$1" ref_line
  ref_line=$(to_reference_line "$ref")
  sed -i "${first_line},${end_line}c\\
${ref_line}" "$target_file"
}

split_task_all() {
  split_task
  # まだ未 split タスクが残っていれば再帰的に処理
  if has_unsplit_task; then
    split_task_all
  fi
}

has_tasks() {
  grep -qE "^$grep_key_task_exists" "$target_file"
}

# 参照行を除いた未完了タスクが残っているか
has_unsplit_task() {
  grep -nE "^$grep_key_task_exists" "$target_file" |
    grep -qvE "^[0-9]+:${grep_key_reference#^}"
}

has_front_matter() {
  head -1 "$target_file" | grep -qx -- '---'
}

# front matter から key の値を取得 (file, key)
front_matter_value() {
  local file="$1" key="$2"
  head -1 "$file" 2>/dev/null | grep -qx -- '---' || return 0
  awk -v k="$key" '
    NR==1 { infm=1; next }
    infm && $0=="---" { exit }
    infm && index($0, k": ")==1 { sub("^" k ": *",""); print; exit }
  ' "$file"
}

# 完了済み参照行 (- [x] [title](path)) を log_fmt へ転記し .tasks.md から削除する。
# done ディレクトリは使わない。タスクdir自体は split 済みのため移動しない。
# log_fmt は .tasks (= repo の保存先ベース) を起点に解決する。
clean_tasks() {
  if ! grep -qE "$grep_key_reference_done" "$target_file"; then
    info "==> No completed task references to clean."
    return 0
  fi
  local base log_path
  base=$(realpath "$git_root/.tasks" 2>/dev/null) ||
    die "==> No .tasks base for clean: $git_root/.tasks"
  log_path="$base/$(expand_log_fmt "$log_fmt")"
  mkdir -p "$(dirname "$log_path")"
  grep -E "$grep_key_reference_done" "$target_file" >>"$log_path"
  sed -i -E "/${grep_key_reference_done}/d" "$target_file"
  info "==> Recorded completed task references to $log_path"
}

complete_task() {
  local complete_mark="✅️"
  # front matter 持ち index.md は body の未完了サブタスクを先に消化し、
  # 残り 0 になった時点で title 全体を完了扱いにする (旧 complete_title_task 同等)
  if has_front_matter && ! has_tasks; then
    complete_front_matter_task
    return
  fi
  complete_normal_task
}

# split で生成した index.md (front matter 持ち) の完了処理
complete_front_matter_task() {
  if grep -qE '^done: *true' "$target_file"; then
    warn "==> Task already marked as completed."
    return 0
  fi
  sed -i 's/^done: *false/done: true/' "$target_file"
  # title 先頭に ✅️ (未付与時のみ)
  if ! grep -qE "^title: *${complete_mark}" "$target_file"; then
    sed -i "s/^title: */&${complete_mark} /" "$target_file"
  fi
  info "==> ${complete_mark} Task title marked as completed"
  grep -E '^title:' "$target_file" | head -1
  mark_parent_reference_done
}

# 親 index.md の当該参照行 (- [ ] [title](.../index.md)) を [x] 化する
mark_parent_reference_done() {
  local parent ref lineno
  parent=$(from_tilde "$(front_matter_value "$target_file" parent)")
  [[ -n $parent && -e $parent ]] || return 0
  ref=${target_file#"$store_root"/}
  [[ $ref != /* ]] ||
    die "==> Task path not under store_root: $target_file (store_root=$store_root)"
  lineno=$(grep -nF -- "(${ref})" "$parent" | head -1 | cut -d: -f1)
  [[ -n $lineno ]] || return 0
  sed -i "${lineno}s/- \[ \]/- [x]/" "$parent"
  info "==> Parent reference marked done: $parent"
}

complete_normal_task() {
  # 参照行は手動完了せず mark_parent_reference_done 経由でのみ [x] 化する一本道にする
  parse_skip_refs=1
  # task_index 番目のタスクを完了にする
  parse_tasks 0 "$task_index"
  # タスクを完了にする
  sed -i "${first_line}s/^- \[ \]/- [x]/" "$target_file"
  info "==> $complete_mark Task marked as completed"
  sed -n "${first_line}p" "$target_file"
}

get_comment_header() {
  case "${comment_type}" in
    requirement) echo "$(get_timestamp_prefix) 🎭 要件(ふるまい)" ;;
    review) echo "$(get_timestamp_prefix) 👀 レビュー修正" ;;
    complete) echo "$(get_timestamp_prefix) 🎉 完了" ;;
    *) die "==> Invalid comment type: ${comment_type}. Use: requirement|review|complete" ;;
  esac
}

read_input_content() {
  input_content=
  if [[ -t 0 ]]; then
    die "==> No input from stdin."
  fi
  input_content=$(cat)

  if [[ -z ${input_content} ]]; then
    die "==> Empty input."
  fi
}

comment_task() {
  local header input_content
  header=$(get_comment_header)

  read_input_content

  parse_tasks 0 "$task_index"

  local temp_file
  temp_file=$(mktemp)
  trap 'rm -f "${temp_file}"' EXIT

  echo "  - ${header}" >"${temp_file}"
  while IFS= read -r line; do
    echo "    ${line}" >>"${temp_file}"
  done <<<"${input_content}"

  sed -i "${end_line}r ${temp_file}" "${target_file}"
  rm -f "${temp_file}"
  trap - EXIT

  info "==> Comment added to task"
}

add_task() {
  local input_content
  read_input_content

  input_content=$(echo "${input_content}" | sed -e '1s/- \[ \] //' -e '1s/- //' -e "1s/^/- [ ] $(get_timestamp_prefix) /")

  if [[ -s ${target_file} ]] && [[ -n $(tail -c1 "${target_file}") ]]; then
    printf '\n' >>"${target_file}"
  fi
  printf '%s\n' "${input_content}" >>"${target_file}"

  info "==> Task added"
}

summary_task() {
  task_dir_name=$(basename "$git_root")
  # front matter の title を概要として表示
  local title task_summary
  title=$(front_matter_value "$target_file" title)
  task_summary=
  [[ -n $title ]] && task_summary=" [${title}]"
  echo "$task_dir_name$task_summary"
}

# split 済みタスク (参照行) から worktree + tmux + CC /task を起動する
spawn_task() {
  local ref_line ref_path index_md branch name worktree_dir worktree_name session base_dir

  ref_line=$(select_reference) || die "==> No reference selected (cancelled)."
  [[ -z $ref_line ]] && die "==> No reference selected."
  ref_path=$(from_reference_line "$ref_line")
  # ref_path は store_root 相対なので絶対パスへ解決する
  index_md="$store_root/$ref_path"
  [[ -e $index_md ]] || die "==> Reference index not found: $index_md"

  branch=$(front_matter_value "$index_md" branch)
  name=$(front_matter_value "$index_md" name)
  [[ -n $branch ]] || die "==> No 'branch' in front matter: $index_md"

  # worktree 作成 (コマンド置換は errexit を発火させるため明示 || die)
  worktree_dir=$(git_worktree -a "$branch") ||
    die "==> Failed to create worktree for: $branch"
  [[ -n $worktree_dir && -e $worktree_dir ]] ||
    die "==> Failed to create worktree for: $branch"
  worktree_name=${branch//\//-}

  # link: worktree/.tasks.md => index.md, worktree/.tasks => {tasks_subdir}/{repo}
  base_dir=$(realpath "$git_root/.tasks")
  [[ -e "$worktree_dir/.tasks.md" ]] || _ln "$index_md" "$worktree_dir/.tasks.md"
  [[ -e "$worktree_dir/.tasks" ]] || _ln "$base_dir" "$worktree_dir/.tasks"

  # tmux セッション作成 + CC で /task 起動
  session="task-${worktree_name}"
  spawn_tmux_session "$session" "$worktree_dir"

  info "==> Spawned worktree: $worktree_dir"
  info "==> tmux session: $session"
}

# 参照行を選ぶ。index 明示時は N 番目、未指定時は fzf
select_reference() {
  local refs
  refs=$(grep -E "$grep_key_reference" "$target_file" || :)
  [[ -z $refs ]] && die "==> No task references found in $target_file"
  if [[ $task_index_explicit -eq 1 ]]; then
    printf '%s\n' "$refs" | sed -n "${task_index}p"
    return
  fi
  printf '%s\n' "$refs" | fzf --reverse --height=40% --prompt='Select task to spawn: '
}

spawn_tmux_session() {
  local session="$1" dir="$2"
  if tmux has-session -t "$session" 2>/dev/null; then
    warn "==> tmux session already exists: $session"
    return 0
  fi
  tmux new-session -d -s "$session" -c "$dir"
  tmux send-keys -t "$session" 'claude "/task"' Enter
}

resolve_target() {
  if [[ -n $task_file ]]; then
    # -f で taskfile を直接指定。git_root はそのファイルの親dirから導出する
    git_root=$(cd "$(dirname "$task_file")" && pwd) || exit 1
    target_file="$git_root/$(basename "$task_file")"
    return
  fi
  # git_rootはworktree内にいる場合はそのworktreeのルートを指す
  git_root=$(git rev-parse --show-toplevel)
  target_file="$git_root/.tasks.md"
}

main() {
  initialize "$@"

  resolve_target
  cd "$git_root" || exit 1

  # config は全モード共通の前提。ここで1回だけ読み込み fail-fast 検証する。
  load_tasks_config

  # .tasks.md(ファイル) と .tasks(ディレクトリ) のリンクが無ければ生成（遅延初期化）
  if [[ $(basename "$target_file") == ".tasks.md" ]]; then
    initialize_links_if_needed
  fi
  [[ -e $target_file ]] || die "==> Task file not found: $target_file"
  # NOTE: fix sed -i overwrite symlink and break link, so use realpath
  target_file=$(realpath "$target_file")

  case $mode in
    next) cat_first_task ;;
    split) split_task ;;
    split-all) split_task_all ;;
    clean) clean_tasks ;;
    comment) comment_task ;;
    add) add_task ;;
    complete) complete_task ;;
    spawn) spawn_task ;;
    summary) summary_task ;;
    *) find_tasks | v ;;
  esac
}
main "$@"
