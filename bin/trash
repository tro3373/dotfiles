# main "$@"
# gomi "$@"
has() { command -v "${1}" >&/dev/null; }
is_inside_git_work_tree() { git rev-parse --is-inside-work-tree >&/dev/null; }
gen_pj_conf() {
  mkdir -p "$(dirname "$pj_conf")"
  cat_pj_conf >"$pj_conf"
}
cat_pj_conf() {
  base_conf="$HOME"/.config/gomi/config.yaml
  if [[ ! -e $base_conf ]]; then
    # generate default config
    gomi --version >&/dev/null
  fi
  sed "s,gomi_dir:.*,gomi_dir: $git_root/.trash,g" "$base_conf"
}
main() {
  has gomi || {
    elog "==> gomi command not found. Please install gomi first."
  }
  if ! is_inside_git_work_tree; then
    gomi "$@"
    return
  fi
  git_root=$(get_git_root)
  pj_conf="$git_root/.trash/.gomi.conf"
  if [[ ! -e $pj_conf ]]; then
    gen_pj_conf
  fi
  gomi --config "$pj_conf" "$@"
}
main "$@"
