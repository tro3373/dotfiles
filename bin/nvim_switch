#!/usr/bin/env -S bash -e

# timestamp=$(date +%Y%m%d.%H%M%S) && readonly timestamp
main() {
  local nvim_config_dst_dir="$HOME/.config/nvim"
  local nvim_config_src_dir="$HOME/.dot/apps/nvim/nvim"
  # if [[ -e $nvim_config_dst_dir && ! -L $nvim_config_dst_dir ]]; then
  #   mv -v "$nvim_config_dst_dir" "$nvim_config_dst_dir.$timestamp"
  # fi
  # if [[ ! -e $nvim_config_dst_dir ]]; then
  #   ln -sv "$nvim_config_src_dir" "$nvim_config_dst_dir"
  # fi

  # lua/ は init.vim では参照されないので、どちらのモードでも共通で貼る
  if [[ ! -e $nvim_config_dst_dir/lua ]]; then
    ln -sv "$nvim_config_src_dir/lua" "$nvim_config_dst_dir/lua"
  fi

  if [[ -e $nvim_config_dst_dir/init.lua ]]; then
    rm -v "$nvim_config_dst_dir/init.lua"
    ln -sv "$HOME/.vimrc" "$nvim_config_dst_dir/init.vim"
    return
  fi

  rm -fv "$nvim_config_dst_dir/init.vim"
  ln -sv "$nvim_config_src_dir/init.lua" "$nvim_config_dst_dir/init.lua"
}
main "$@"
