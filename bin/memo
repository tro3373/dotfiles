#!/usr/bin/env -S bash -e

current_dir=$(realpath "$(pwd)") && readonly current_dir
src_root_dir="$HOME/.mo" && readonly src_root_dir

find_log_files() {
  rg --files --type md "$src_root_dir/$1/" |
    sort |
    tail -10
}

fire_logs() {
  {
    find_log_files job
    find_log_files prv
  } |
    while read -r f; do
      [[ -z $f ]] && continue
      [[ $f =~ ^#.* ]] && continue
      [[ ! -e $f ]] && continue
      printf "%s\t%s\n" "$(stat -c %Y "$f" 2>/dev/null || echo 0)" "$f"
    done |
    sort -nr |
    cut -f2-
}

cat_memos() {
  memo="$1/.memo"
  if [[ -e $memo ]]; then
    cat <"$memo"
  fi
}

fire_memos() {
  git_root="$(get_git_root || :)"
  [[ -z $git_root ]] && return 0
  git_root=$(realpath "$(get_git_root)")
  if [[ $current_dir != "$git_root" ]]; then
    cat_memos "$git_root"
  fi
  cat_memos "$current_dir"
}

fire() {
  {
    fire_memos
    fire_logs
  } |
    sed -e "s|$current_dir/||g"
}

main() {
  fire | v "$@"
}
main "$@"
