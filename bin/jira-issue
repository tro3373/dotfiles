#!/usr/bin/env bash

# Create or open Jira sub-task(s) for a parent issue.
#
# The config file is selected per-project from JIRA_PROJECT:
#   ${XDG_CONFIG_HOME:-~/.config}/.jira/.config.<JIRA_PROJECT>.yml
# If it is missing, `jira init` runs once, reusing the connection settings
# (server/login/auth/installation) from the most recent existing config in
# that directory when present (otherwise jira init prompts for everything).
# This matters because issue type names differ per project (team-managed
# projects in particular), and `jira issue create` decides the sub-task parent
# from the per-project issue type cache, not from the server.
#
# Open (default): pick an issue with fzf, convert it to task-list markdown,
# then view it in nvim.
#   jira-issue
# To tasks: same pick + convert, but append the result to .tasks.md via
# `tasks -a` instead of opening nvim.
#   jira-issue -t
# Create (stdin):
#   cat task.md | jira-issue add
#     - [ ] タスク名
#       - タスクの説明1
#         - タスクの説明1の詳細
#       - タスクの説明2
#
# Required environment variables:
#   JIRA_PROJECT      - Jira project key (also selects the config file)
#
# Required for `add` (optional filters for the default open view):
#   JIRA_ISSUE_TYPE   - Sub-task issue type name for THIS project
#   JIRA_ISSUE_PARENT - Parent task key
#
# Optional environment variables:
#   JIRA_ASSIGNEE     - Assignee (username / email / display name).
#                       Defaults to "$$" (current logged-in user).
#   JIRA_CONFIG_FILE  - Override the per-project config path.

command_name=$(basename "$0") && readonly command_name
has() { command -v "${1}" >&/dev/null; }
hass() { for _arg in "$@"; do has "$_arg" || die "==> No $_arg command exist."; done; }
_ink() { if has ink; then ink "$@"; else cat - 1>&2; fi; }
#_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") $(test ! -t 0 && cat -) ${@:2}" | _ink "$1"; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
die() { _log red "$*" && exit 1; }

usage() {
  cat <<EOF

$command_name [-t|--to-tasks] [-a|--add]

  Open (default): pick an issue with fzf, convert it to task-list markdown,
  Options:
    -t, --to-tasks  Append the selected issue to .tasks.md instead of opening it in nvim
    -a, --add       Create sub-task(s) from stdin (task-list markdown)
    -h, --help      Show this help message and exit

EOF
}

require_env() {
  local name=$1
  if [[ -z ${!name:-} ]]; then
    echo "==> Error: ${name} is not set" >&2
    return 1
  fi
}

validate_env() {
  require_env JIRA_PROJECT
}

validate_add_env() {
  # Sub-task creation needs an explicit type and parent; the open view treats
  # both as optional filters.
  require_env JIRA_ISSUE_TYPE
  require_env JIRA_ISSUE_PARENT
}

read_config_value() {
  # First top-level "<key>: <value>" scalar from a jira config yaml.
  local file=$1 key=$2 line
  while IFS= read -r line; do
    if [[ ${line} == "${key}: "* ]]; then
      printf '%s\n' "${line#"${key}": }"
      return 0
    fi
  done <"${file}"
}

newest_config() {
  # Most recently modified jira config in the dir, used to seed connection
  # settings for a new project. Empty if none exist yet (first ever run).
  local dir=$1 newest="" f
  for f in "${dir}"/.config*.yml; do
    [[ -f ${f} ]] || continue
    [[ -z ${newest} || ${f} -nt ${newest} ]] && newest=${f}
  done
  printf '%s\n' "${newest}"
}

init_config() {
  # Create the per-project config once. Seed the connection settings from the
  # most recent existing config so only the board prompt (if any) needs the
  # terminal; on the very first run none exist, so jira init asks for them.
  local donor
  donor=$(newest_config "${JIRA_CONFIG_FILE%/*}")
  echo "==> No config for project ${JIRA_PROJECT}; running 'jira init' -> ${JIRA_CONFIG_FILE}" >&2
  local args=(--project "${JIRA_PROJECT}")
  if [[ -n ${donor} ]]; then
    echo "==> Reusing connection settings from ${donor}" >&2
    local installation server login auth_type
    installation=$(read_config_value "${donor}" installation)
    server=$(read_config_value "${donor}" server)
    login=$(read_config_value "${donor}" login)
    auth_type=$(read_config_value "${donor}" auth_type)
    [[ -n ${installation} ]] && args+=(--installation "${installation,,}")
    [[ -n ${server} ]] && args+=(--server "${server}")
    [[ -n ${login} ]] && args+=(--login "${login}")
    [[ -n ${auth_type} ]] && args+=(--auth-type "${auth_type}")
  fi
  jira init "${args[@]}" </dev/tty
}

resolve_config() {
  # Pick the per-project config from JIRA_PROJECT; init it on first use.
  local dir="${XDG_CONFIG_HOME:-${HOME}/.config}/.jira"
  export JIRA_CONFIG_FILE="${JIRA_CONFIG_FILE:-${dir}/.config.${JIRA_PROJECT}.yml}"
  [[ -f ${JIRA_CONFIG_FILE} ]] || init_config
}

validate_stdin() {
  if [[ -t 0 ]]; then
    echo "==> Error: No stdin input" >&2
    echo "Usage: cat task.md | $0 add" >&2
    return 1
  fi
}

emit_task() {
  [[ -z ${summary} ]] && return 0
  echo "==> Creating: ${summary}" >&2
  printf '%s' "${body}" |
    jira issue create \
      -p "${JIRA_PROJECT}" \
      -t "${JIRA_ISSUE_TYPE}" \
      -P "${JIRA_ISSUE_PARENT}" \
      -s "${summary}" \
      -a "${assignee}" \
      --no-input
  summary=""
  body=""
}

process_tasks() {
  local task_re='^- \[[x ]\] (.*)$'
  local line=""
  local summary=""
  local body=""
  while IFS='' read -r line || [[ -n ${line} ]]; do
    if [[ ${line} =~ ${task_re} ]]; then
      emit_task
      summary="${BASH_REMATCH[1]}"
      body=""
      continue
    fi
    [[ -z ${summary} ]] && continue
    body+="${line#  }"$'\n'
  done
  emit_task
}

list_issues_plain() {
  # Tab-delimited list for fzf. TYPE/PARENT are optional filters, so only pass
  # them when set (lets listing work without a fixed type/parent).
  local args=(-p "${JIRA_PROJECT}")
  [[ -n ${JIRA_ISSUE_TYPE:-} ]] && args+=(-t "${JIRA_ISSUE_TYPE}")
  [[ -n ${JIRA_ISSUE_PARENT:-} ]] && args+=(-P "${JIRA_ISSUE_PARENT}")
  jira issue list "${args[@]}" \
    --plain --no-headers --columns KEY,SUMMARY,STATUS,ASSIGNEE
}

issue_to_tasks() {
  # Convert `jira issue view --plain` output into markdown task-list format:
  #   # Title                 -> - [ ] Title
  #   • item                  -> - item   (4-space nesting -> 2-space nesting)
  #   other body lines        -> - <line> (bulletized, one level under title)
  # Everything up to the "Description" separator is dropped (the title is
  # captured beforehand). Blank lines, empty bullets and ANSI escapes are
  # stripped, and the whole body is nested one level under the title.
  # jira renders through glamour, which hard-wraps at 120 columns; wrapped
  # continuation lines are joined back so a split URL stays a single URL
  # instead of turning its tail into its own bullet (see unwrap notes below).
  local title="" desc_seen=0 line content indent lead margin=-1 joinable=0 last
  local title_re='^[[:space:]]*# +(.*)$'
  local desc_re='^[[:space:]]*-+.*Description.*-+[[:space:]]*$'
  local bullet_re='^( *)• +(.*)$'
  local any_bullet_re='^[[:space:]]*•'
  local empty_bullet_re='^[[:space:]]*•[[:space:]]*$'
  # glamour wraps at " ,.;-+|": a breakpoint char stays at the end of the line
  # it broke, while a wrap on whitespace swallows that one space. The two are
  # indistinguishable afterwards, so prose that wraps right after ",.;-+|"
  # loses that space ("a. B" -> "a.B"); intact URLs are worth that much.
  local breakpoint_re='[,.;+|-]$'
  local -a body=()
  # Pass 1: strip ANSI up front, capture the title, and collect the body lines
  # after the Description separator (tracking their smallest leading margin).
  # glamour folds source newlines inside a block into spaces, so any non-blank
  # line that follows another one without starting a bullet is a wrap remnant.
  while IFS='' read -r line || [[ -n ${line} ]]; do
    line="${line%"${line##*[![:space:]]}"}" # trim trailing whitespace
    if [[ ${desc_seen} -eq 0 ]]; then
      [[ ${line} =~ ${title_re} ]] && title="${BASH_REMATCH[1]}"
      [[ ${line} =~ ${desc_re} ]] && desc_seen=1
      continue
    fi
    [[ -z ${line} ]] && { # blank line: ends the wrapped block
      joinable=0
      continue
    }
    [[ ${line} =~ ${empty_bullet_re} ]] && { # empty bullet: ditto
      joinable=0
      continue
    }
    if ((joinable)) && [[ ! ${line} =~ ${any_bullet_re} ]]; then
      content=${line#"${line%%[![:space:]]*}"} # strip leading whitespace
      last=${body[-1]}
      [[ ${last} =~ ${breakpoint_re} ]] || last+=" " # restore swallowed space
      body[-1]="${last}${content}"
      continue
    fi
    lead=${line%%[![:space:]]*} # leading whitespace run
    ((margin < 0 || ${#lead} < margin)) && margin=${#lead}
    body+=("${line}")
    joinable=1
  done < <(sed -E $'s/\x1b\\[[0-9;?]*[a-zA-Z]//g')
  ((margin < 0)) && margin=0

  [[ -n ${title} ]] && printf -- '- [ ] %s\n' "${title}"
  # Pass 2: dedent jira's common left margin so bullet nesting is measured from
  # column 0, then bulletize each line and nest it one level under the title.
  for line in ${body[@]+"${body[@]}"}; do
    line=${line:margin}
    if [[ ${line} =~ ${bullet_re} ]]; then
      indent=${#BASH_REMATCH[1]}
      content=${BASH_REMATCH[2]}
      printf '  %*s- %s\n' $((indent / 2)) '' "${content}" # halve indent, nest
      continue
    fi
    content=${line#"${line%%[![:space:]]*}"} # strip leading whitespace
    printf '  - %s\n' "${content}"           # bulletize non-bullet line
  done
}

issue_select_open() {
  # Pick an issue with fzf (KEY is the first tab field), convert it to task
  # list markdown, then open it in nvim (default) or append it to .tasks.md
  # (to-tasks mode). JIRA_CONFIG_FILE is exported, so the preview/view
  # subprocesses inherit the per-project config.
  local mode="${1:-open}"
  local line key
  line=$(
    list_issues_plain |
      fzf --delimiter '\t' \
        --preview 'jira issue view {1} --plain' \
        --preview-window 'right,60%,wrap' \
        --select-1 --exit-0
  ) || return 0
  [[ -z ${line} ]] && return 0
  key=${line%%$'\t'*}
  # Same pick + convert; only the sink differs (append vs open in nvim).
  local -a sink=(nvim -c 'setf markdown' -)
  [[ ${mode} == to-tasks ]] && sink=(tasks -a)
  jira issue view "${key}" --plain | issue_to_tasks | "${sink[@]}"
}

main() {
  set -euo pipefail
  if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
    usage
    return 0
  fi
  validate_env
  resolve_config
  if [[ ${1:-} == "-a" || ${1:-} == "--add" ]]; then
    validate_add_env
    local assignee="${JIRA_ASSIGNEE:-}"
    [[ -z ${assignee} ]] && assignee='$$'
    validate_stdin
    process_tasks
    return
  fi
  if [[ ${1:-} == "-t" || ${1:-} == "--to-tasks" ]]; then
    issue_select_open to-tasks
    return
  fi
  issue_select_open
}
if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  main "$@"
fi
