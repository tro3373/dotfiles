#!/usr/bin/env python
# -*- coding: utf-8 -*-

"""cat xls content."""

import argparse
import re
# import os

import openpyxl

# Variable define ============================================================
# TODO
TARGET_SHEET_NAMES = ["^[tm]_.+"]
IGNORE_SHEET_NAMES = [".*_データ$"]
MAX_ROW = 1000
START_HANDLE_COL = 1
START_HANDLE_VAL = "No"
CONST_CELLS = [
    [1, 23],
    [2, 23],
]
OUT_COLS = [1, 3, 11, 19, 23, 25, 27, 30, 32]
# ============================================================================

# def get_xls():
#     # print(os.getcwd())
#     # print(input())
#     return '1.xlsx'


def get_start_row(sheet):
    for i in range(1, 10):
        value = sheet.cell(row=i, column=START_HANDLE_COL).value
        if (value == START_HANDLE_VAL):
            return (i + 1)
    return 5


def for_sheet(wb, sheetname):
    # print(f"===> SHEET:{sheetname}")
    sheet = wb[sheetname]
    start_row = get_start_row(sheet)
    const_val1 = sheet.cell(row=CONST_CELLS[0][0], column=CONST_CELLS[0][1]).value
    const_val2 = sheet.cell(row=CONST_CELLS[1][0], column=CONST_CELLS[1][1]).value
    # print(sheet['A1'].value)
    # print(start_row)
    row = start_row
    max_col = OUT_COLS[len(OUT_COLS)] + 1
    while True:
        row_values = ""
        for col in range(1, max_col):
            # print(row)
            # print(col)
            if (col not in OUT_COLS):
                continue
            value = sheet.cell(row=row, column=col).value
            # print(f"row:{row} col:{col} val:{value}")
            # if (col == 1):
            #     if not value:
            #         return
            #     continue
            if value == None:
                if col == 1:
                    return
                value = ""
                # continue
            value = f"{value}"
            value = re.sub("\n", "", value)
            value = re.sub("”", "\"", value)
            # if (value == "特になし" or value == "。"):
            #     value = ""
            if (row_values):
                value = f"\t{value}"
            row_values = f"{row_values}{value}"
            # print(f"{tab}{value}", end="")
        if (row_values):
            print(f"{const_val1}\t{const_val2}\t{row_values}")
        row += 1
        if (row >= MAX_ROW):
            # print("--------------------")
            return

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("path", help="Specify xlsx file path", type=str)
    parser.add_argument("--list", "-l", help="Optional show sheet name only",
                        action="store_true")
    args = parser.parse_args()
    # args.param

    # file_path = get_xls()
    # wb = openpyxl.load_workbook(file_path)
    wb = openpyxl.load_workbook(args.path, data_only=True)
    no = 0
    for sheetname in wb.sheetnames:
        if args.list:
            print(sheetname)
            continue
        no += 1
        if not re.match(TARGET_SHEET_NAMES[0], sheetname) or re.match(IGNORE_SHEET_NAMES[0], sheetname):
          continue
        # print(f"{no}:{sheetname}")
        # if (no == 1):
        #     continue
        for_sheet(wb, sheetname)
        # break


if __name__ == "__main__":
    main()
