#!/usr/bin/env bash

main() {
  set -eo pipefail
  git_root=$(get_git_root)
  [[ -z $git_root ]] && elog "==> Error: Failed to get git root: $git_root"
  local dst="$git_root/.tasks.md"
  if [[ ! -e $dst ]]; then
    elog "==> Error: .tasks.md not found in this repository."
    exit 1
  fi
  local pr_no=$1
  if [[ -z $pr_no ]]; then
    # 現在のブランチのPR番号を取得
    pr_no=$(gh pr view --json number -q .number 2>/dev/null)
    if [[ -z $pr_no ]]; then
      ilog "==> Input PR No! Press Enter to continue..(Cancel: Ctrl+C)"
      read -r pr_no
    fi
  fi
  if [[ -z $pr_no || ! $pr_no =~ ^[0-9]+$ ]]; then
    elog "==> Error: Invalid PR number. $pr_no"
    exit 1
  fi
  gh_pr_review_to_tasks "$pr_no" >>"$dst"
  echo "$dst" | v
}
main "$@"
