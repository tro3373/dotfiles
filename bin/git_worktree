#!/usr/bin/env bash

command_name=$(basename "$0") && readonly command_name
worktree_dir_suffix="worktree" && readonly worktree_dir_suffix
repo_root_label="RepositoryRoot" && readonly repo_root_label
readonly depends=(git fzf)
mode=list
branch=
commit_hash=
remove_after_merge=0
args=()
usage() {
  cat <<EOF

Add a new git worktree for the specified branch(or Remove it).

  Usage:
      $command_name [option] <branch_name> <commit_hash>
    Options
      -h|--help : Show this usage
      -l        : List all worktrees with switch (default)
      -a        : Add a worktree for the specified branch
      -r        : Remove the worktree instead of adding it
      -m        : Merge a worktree branch into the current branch
      -mr       : Merge and then remove the worktree
      -e        : Edit config

EOF
}
initialize() {
  while true; do
    [[ -z $1 ]] && break
    case "$1" in
      -h | --help) usage && exit 0 ;;
      -l) mode=list ;;
      -r) mode=remove ;;
      -a) mode=add ;;
      -m) mode=merge ;;
      -mr) mode=merge && remove_after_merge=1 ;;
      -e) mode=edit_config ;;
      *) add_args "$1" ;;
    esac
    shift
  done
  check
  set -euo pipefail
}
check() {
  hass "${depends[@]}"

  branch="${args[0]}"
  commit_hash="${args[1]}"

  if [[ $mode == "add" && -z $branch ]]; then
    cat <<EOF | ink red
==> Specify a branch name to add a worktree for.
==> Exiting branch is..

$(git branch -vv)

EOF
    exit 1
  fi
}
add_args() { args+=("$@"); }
has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || elog "==> No $arg command exist."; done; }
is_exist_branch() {
  git show-ref --verify --quiet "refs/heads/$1" || git show-ref --verify --quiet "refs/remotes/origin/$1"
}

get_org_git_root() {
  # NOTE: git rev-parse --git-common-dir: Get the common git directory path
  #   - this show               .git if in original repo root directory
  #   - this show            ../.git if in original repo sub-directory
  #   - this show /path/to/repo/.git if in worktree
  #   - this show            ../.git if in worktree sub-directory
  realpath "$(dirname "$(git rev-parse --git-common-dir)")"
}

get_worktree_branch_name() {
  # Replace slashes with hyphens for the branch name
  echo "${branch//\//-}"
}

_fzf_worktrees() {
  # shellcheck disable=SC2016
  fzf \
    --exit-0 \
    --reverse \
    --height=100% \
    --bind 'ctrl-l:toggle-all' \
    --preview='p=$(echo {} | awk "{print \$NF}")/.tasks.md; [ -e "$p" ] && bat --color=always "$p" || echo "(no tasks file)"' \
    --preview-window=down:70% \
    "$@"
}

show_change_directory_command() {
  _list_root_and_worktree_directories |
    _fzf_worktrees \
      --no-multi \
      --prompt="Select worktree branches to change directory: " |
    awk '{print $NF}' |
    while read -r branch_path; do
      [[ -z $branch_path ]] && continue
      [[ $branch_path =~ ^#.* ]] && continue
      echo "$branch_path"
    done
}

_list_root_and_worktree_directories() {
  {
    # show worktrees sorted by updated time
    ls -td "$git_worktree_dir"/*/ 2>/dev/null || :
    # show repo root directory
    echo "$git_org_root_dir"
  } |
    while read -r _target_path; do
      [[ -z $_target_path ]] && continue
      [[ $_target_path =~ ^#.* ]] && continue
      label="($repo_root_label)"
      if [[ $_target_path =~ ^$git_worktree_dir/ ]]; then
        # 一覧は read-only に保つ: リンク未生成 worktree で tasks を起動して
        # 自己修復(ファイル生成)させない。実体があるときだけ summary を引く。
        label='(no tasks)'
        [[ -e "${_target_path%/}/.tasks.md" ]] &&
          label=$(tasks --summary -f "${_target_path%/}/.tasks.md" 2>/dev/null || echo '(no tasks)')
      fi
      _time=$(stat -c %y "$_target_path" | cut -d. -f1 | sed -e 's, ,_,g')
      printf "%s\t%s\t%s\n" "$_time" "$label" "$_target_path"
    done | sort -k 2 | column -t -s $'\t'

}

_add_worktree() {
  if [[ ! -e $ln_config ]]; then
    wlog "==> No config file exist."
    # read -r -n 1 -p "==> Create config file? (Y/n): "
    # if ! [[ $REPLY =~ ^[Nn]$ ]]; then
    #   create_default_ln_config
    # fi
    create_default_ln_config
  fi
  dst_dir="$git_worktree_dir/$(get_worktree_branch_name)"

  ilog "==> Adding worktree to $dst_dir for $branch branch hash:$commit_hash.."
  # shellcheck disable=SC2206
  local cmd_args=(-b "$branch" "$dst_dir" $commit_hash)
  if is_exist_branch "$branch"; then
    ilog "==> Branch '$branch' already exists. Using existing branch."
    # NOTE: commit_hash is intentionally ignored here;
    # an existing branch already has its own tip and
    # `git worktree add <path> <branch>` does not accept a base ref.
    cmd_args=("$dst_dir" "$branch")
  fi
  git worktree add "${cmd_args[@]}" 1>&2 || {
    elog "Failed to add worktree to $dst_dir for branch '$branch'."
  }

  ln_ignored_from_config 1>&2
  ilog "==> Added worktree for branch '$branch' at '$dst_dir'."

  # Print the worktree path; the zsh wrapper cd's into it when it is a valid dir.
  echo "$dst_dir"
}

ln_ignored_from_config() {
  [[ ! -e $ln_config ]] && {
    wlog "==> No config file exist. Skipping linking ignored files."
    return
  }
  cat <"$ln_config" |
    sed -e "s|/$||" |
    while read -r rel_path; do
      [[ -z $rel_path ]] && continue
      [[ $rel_path =~ ^#.* ]] && continue
      src="$git_org_root_dir/$rel_path"
      [[ ! -e $src ]] && {
        wlog "==> Ignored path '$rel_path' does not exist in the repository. Skipping linking."
        continue
      }
      dst="$dst_dir/$rel_path"
      _dst_dir="$(dirname "$dst")"
      [[ ! -e $_dst_dir ]] && mkdir -p "$_dst_dir"

      _ln "$src" "$dst"
      # # NOTE: For support git ignored `xxxx/` pattern
      # #   - Make directory and link all its content instead of
      # #     linking the directory itself to avoid detect directory changed
      # if [[ -f $src ]]; then
      #   # File case
      #   _ln "$src" "$dst"
      #   continue
      # fi
      # # Directory case
      # mkdir -p "$dst"
      # src="$(realpath "$src")" # Resolve to absolute path
      # find "$src/" -maxdepth 1 -mindepth 1 |
      #   while read -r item_path; do
      #     item_name=$(basename "$item_path")
      #     _ln "$item_path" "$dst/$item_name"
      #   done || :
    done
}

_ln() {
  ilog "==> Linking via: ln -s '$1' '$2'"
  ln -s "$1" "$2"
}

create_default_ln_config() {
  git status --ignored --porcelain 2>/dev/null |
    grep '^!!' |
    grep -Ev '(\.tasks(\.md|/|$)|\.trash|node_modules|.next|tsconfig.tsbuildinfo|.data|-data)' |
    cut -c4- >"$ln_config"
  # fzf \
  #   --prompt="Select ignored files/directories to link in new worktree: " \
  #   --bind 'ctrl-l:toggle-all' \
  #   --reverse \
  #   --multi \
  #   --exit-0 >"$ln_config"
}

_rename_removed_branch() {
  # Rename the worktree's branch to removed/<branch> so it can be cleaned up
  # later with `git branch -d` (which refuses unmerged branches as a safety
  # net). No merge detection here on purpose: git itself is the authority on
  # whether the branch is safe to delete.
  local target_path="$1"
  local cur
  cur=$(git -C "${target_path}" rev-parse --abbrev-ref HEAD 2>/dev/null) || return 0
  [[ -z $cur || $cur == "HEAD" || $cur == removed/* ]] && return 0

  local renamed="removed/${cur}"
  ilog "==> Renaming branch '${cur}' -> '${renamed}'.."
  git branch -m "${cur}" "${renamed}" ||
    wlog "==> Failed to rename branch '${cur}' -> '${renamed}'. Continuing removal."
}

_do_remove_worktree() {
  local target_path="$1"

  # 削除前に「呼び出し時の現在地そのもの」かを判定しておく (削除後は realpath 不可)。
  local removing_current=0
  if is_invoked_from_worktree &&
    [[ "$(realpath "${target_path%/}")" == "$initial_toplevel" ]]; then
    removing_current=1
  fi

  tasks --clean --all -f "${target_path%/}/.tasks.md" 1>&2 || :

  _rename_removed_branch "${target_path}"

  ilog "==> Removing worktree path: '${target_path}'.."
  if ! git worktree remove "${target_path}" && [[ -e ${target_path} ]]; then
    wlog "==> Worktree path '${target_path}' still exists. Force remove? (Cancel: Ctrl+C)"
    read -r _
    sudo rm -rfv "${target_path}"
  fi

  # 現在地の worktree を消した場合のみ org root を stdout に出す。zsh wrapper(gt) が
  # これを受けて削除済み dir から org root へ cd し直し、シェルの宙ぶらりんを防ぐ。
  if [[ $removing_current -eq 1 && ! -e ${target_path} ]]; then
    echo "$git_org_root_dir"
  fi
}

_merge_worktree() {
  local merge_target_dir="$git_org_root_dir"
  if is_invoked_from_worktree; then
    # When invoked from a worktree, target that worktree's branch.
    # NOTE: keep elog calls at simple-command position; bash -e cannot
    # propagate from inside $(...) since command substitution does not
    # inherit errexit (and external elog's exit only kills the subshell).
    local current_branch
    current_branch=$(git -C "$initial_toplevel" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
    if [[ -z $current_branch || $current_branch == "HEAD" ]]; then
      elog "==> Worktree '$initial_toplevel' is in detached HEAD or branch detection failed. Move to repository root or checkout a branch first."
    fi
    merge_target_dir="$initial_toplevel"
  fi

  # shellcheck disable=SC2016
  while read -r branch_path; do
    [[ -z ${branch_path} ]] && continue

    local merge_branch
    merge_branch=$(git -C "${branch_path}" rev-parse --abbrev-ref HEAD)

    ilog "==> Merging branch '${merge_branch}' into current branch at '${merge_target_dir}'.."
    if ! git -C "${merge_target_dir}" merge "${merge_branch}"; then
      elog "Failed to merge branch '${merge_branch}'."
    fi
    ilog "==> Successfully merged branch '${merge_branch}'."

    if [[ ${remove_after_merge} -ne 1 ]]; then
      continue
    fi

    _do_remove_worktree "${branch_path}"
  done < <(
    _list_root_and_worktree_directories |
      grep -v "${repo_root_label}" |
      _fzf_worktrees \
        --no-multi \
        --prompt="Select worktree branch to merge: " |
      awk '{print $NF}'
  )
}

_remove_worktree() {
  removal_list=$(_list_removal_worktrees)
  if [[ -z ${removal_list} ]]; then
    elog "No worktrees exist to remove."
  fi

  # shellcheck disable=SC2016
  while read -r branch_path _; do
    [[ -z ${branch_path} ]] && continue
    [[ ${branch_path} =~ ^#.* ]] && continue

    _do_remove_worktree "${branch_path}"
  done < <(
    _list_root_and_worktree_directories |
      grep -v "${repo_root_label}" |
      _fzf_worktrees \
        --multi \
        --prompt="Select branch to remove worktree for: " |
      awk '{print $NF " " $2}'
  )
}

_list_removal_worktrees() {
  git worktree list |
    grep "$git_worktree_dir"
}

_edit_config() {
  if [[ ! -e $ln_config ]]; then
    create_default_ln_config
  fi
  wlog "==> Editing config file.."
  echo "$ln_config" | v
}

capture_initial_toplevel() {
  # Capture the worktree we were invoked from BEFORE main cd's into the
  # original repository root. Used by add/merge to honor the current
  # worktree's branch instead of forcing the org root.
  local toplevel
  toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  [[ -z $toplevel ]] && return 0
  initial_toplevel=$(realpath "$toplevel")
}

is_invoked_from_worktree() {
  [[ -n $initial_toplevel && $initial_toplevel != "$git_org_root_dir" ]]
}

resolve_commit_hash_from_current_worktree() {
  # When adding a new worktree from inside another worktree directory without
  # an explicit commit/branch base, use that worktree's current branch as the
  # base instead of falling back to the original repository root's HEAD.
  [[ $mode != "add" ]] && return 0
  [[ -n $commit_hash ]] && return 0
  is_invoked_from_worktree || return 0

  local current_branch
  current_branch=$(git -C "$initial_toplevel" rev-parse --abbrev-ref HEAD 2>/dev/null) || return 0
  # Guard: detached HEAD returns the literal string "HEAD".
  if [[ -z $current_branch || $current_branch == "HEAD" ]]; then
    wlog "==> Worktree '$initial_toplevel' is in detached HEAD. Falling back to default base."
    return 0
  fi

  commit_hash=$current_branch
  ilog "==> Running inside worktree '$initial_toplevel'. Using its current branch '$commit_hash' as base."
}

main() {
  initialize "$@"

  git_org_root_dir=$(get_org_git_root)
  initial_toplevel=
  capture_initial_toplevel
  resolve_commit_hash_from_current_worktree
  cd "$git_org_root_dir" || {
    elog "Failed to change directory to git root: $git_org_root_dir"
  }
  git_worktree_dir="${git_org_root_dir}-$worktree_dir_suffix"
  if [[ ! -e $git_worktree_dir ]]; then
    mkdir -p "$git_worktree_dir"
  fi
  local ln_config="$git_worktree_dir/config"

  case "$mode" in
    add) _add_worktree ;;
    merge) _merge_worktree ;;
    remove) _remove_worktree ;;
    edit_config) _edit_config ;;
    *) show_change_directory_command ;;
  esac
}
# main "$@"
if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  main "$@"
fi
