#!/usr/bin/env bash

mo=~/ghq/github.com/tro3373/mo
news_letter=~/ghq/github.com/tro3373/news-letter
src_dirs=("$mo" "$news_letter")
has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || error "==> No $arg command exist."; done; }
_ink() { if has ink; then ink "$@"; else cat - 1>&2; fi; }
#_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") $(test ! -t 0 && cat -) ${@:2}" | _ink "$1"; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
error() { _log red "$*" && exit 1; }
updated_src_dirs() {
  mark=/tmp/news.updated
  [[ -e $mark ]] && return
  for src_dir in "${src_dirs[@]}"; do
    info "==> Updating $src_dir.."
    (cd "$src_dir" && git pull --rebase) || true
  done
  touch "$mark"
}
fire() {
  {
    find "$mo"/dr/ -maxdepth 1 -mindepth 1 -type f -name "*.md"
    find "$news_letter"/ideas/daily/ -maxdepth 1 -mindepth 1 -type f -name "*-trend.md"
  } |
    while read -r line; do
      [[ -z $line ]] && continue
      echo "$(basename "$line" | sed -e 's,-,,g') $line"
    done
}
main() {
  set -eo pipefail
  updated_src_dirs
  fire |
    sort -nr -k 1 |
    cut -d' ' -f2 |
    fzf -m \
      --preview 'echo {}; echo "----------------------------------------"; head -100 {}' \
      --select-1 \
      --exit-0 \
      --bind 'ctrl-l:toggle-all,ctrl-g:toggle-preview' |
    v
}
main "$@"
