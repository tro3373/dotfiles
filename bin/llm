#!/usr/bin/env -S bash -e

command_name=$(basename "$0") && readonly command_name
# readonly depends=(gemini-cli tgpt claude gemini)
add_args() { args+=("$@"); }
args=()
cmd=
fallback_cmd=
provider=
model=
key=

usage() {
  cat <<EOF

$command_name - LLM command line interface.
                Execute the instructions from standard input using LLMs.

  Usage:
      $command_name [option]
    Options
      -h|--help     : Show this usage
      -c|--cmd      : Specify the LLM cmd (default: tgpt)
                      Available modes: gemini-cli, tgpt, claude, gemini
      -fc|--fallback-cmd : Specify the fallback cmd used when the primary cmd fails
      -p|--provider : Specify the provider for tgpt (default: gemini)
      -m|--model    : Specify the model to use
      -k|--key      : Specify the API key for the provider

EOF
}
initialize() {
  set -eo pipefail
  while true; do
    [[ -z $1 ]] && break
    case "$1" in
      -h | --help) usage && exit 0 ;;
      # -e) dummy= ;;
      # -f*|--file*) file=${1#*=} ;;
      --cmd | -c) shift && cmd="$1" ;;
      --fallback-cmd | -fc) shift && fallback_cmd="$1" ;;
      --provider | -p) shift && provider="$1" ;;
      --model | -m) shift && model="$1" ;;
      --key | -k) shift && key="$1" ;;
      *) add_args "$1" ;;
    esac
    shift
  done
}

fire() {
  if [[ ! -t 0 ]]; then
    cat -
  fi
  if [[ $# -ne 0 ]]; then
    echo "$@"
  fi
}

_tgpt() {
  hass tgpt
  # ## aandrew-me/tgpt: AI Chatbots in terminal without needing API keys
  # - https://github.com/aandrew-me/tgpt?tab=readme-ov-file
  # ### Provider
  # - deepseek, gemini, groq, isou, koboldai, ollama, openai, pollinations and phind(default)
  # ### Provider Groq
  # - Supported Models - GroqDocs
  #   - https://console.groq.com/docs/models
  # provider=groq model=gemma2-9b-it API_KEY=$GROQ_API_KEY
  # provider=gemini API_KEY=$GEMINI_API_KEY model=gemini-2.5-flash-preview-05-20
  # provider=gemini API_KEY=$GEMINI_API_KEY model=gemini-2.5-flash-lite-preview-06-17
  if [[ -z $provider ]]; then
    provider=gemini
  fi
  if [[ $provider == "gemini" ]]; then
    [[ -z $model ]] && model=$GEMINI_MODEL
    [[ -z $key ]] && key=$GEMINI_API_KEY
  fi
  if [[ $provider == "groq" ]]; then
    # [[ -z $model ]] && model=gemma2-9b-it
    [[ -z $model ]] && model=openai/gpt-oss-120b
    [[ -z $key ]] && key=$GROQ_API_KEY
  fi
  command tgpt --quiet --provider "$provider" --model "$model" --key "$key"
}

_claude() {
  hass claude
  # tmp_org=/tmp/llm-claude-prompt-org.md
  # cat - >$tmp_org
  # command claude -p "$tmp_org の指示を実行して"
  # command claude -p "標準入力からの指示を実行して."
  command claude --model haiku --dangerously-skip-permissions -p "Execute the instructions from standard input." # --output-format json
}

_codex() {
  hass codex
  command codex exec -
}

_gemini() {
  hass gemini
  command gemini -y -p "" | grep -v '^Data collection is disabled.'
}

_eliben_gemini_cli() {
  hass gemini-cli
  [[ -z $model ]] && model=$GEMINI_MODEL
  [[ -z $key ]] && key=$GEMINI_API_KEY
  command gemini-cli --model "$model" --key "$key" prompt -
}

_dispatch() {
  case "$1" in
    claude) _claude ;;
    codex) _codex ;;
    gemini) _gemini ;;
    gemini-cli) _eliben_gemini_cli ;;
    *) _tgpt ;;
  esac
}

_llm() {
  local input
  input=$(cat -)
  # Run primary in a subshell so a hard failure (e.g. hass/die on a missing
  # binary) becomes a non-zero return that triggers the fallback cmd.
  (_dispatch "$cmd") <<<"$input" && return 0
  [[ -z $fallback_cmd ]] && return 1
  elog "==> Command '${cmd:-tgpt}' failed. Fallback to '$fallback_cmd'."
  _dispatch "$fallback_cmd" <<<"$input"
}

main() {
  initialize "$@"
  if [[ ${#args[@]} -eq 0 && -t 0 ]]; then
    elog "==> No input data."
  fi
  fire "${args[@]}" | _llm
}
main "$@"
