#!/usr/bin/env bash

fire() {
  [[ $# -gt 0 ]] && echo "$@" && return
  if [[ ! -t 0 ]]; then
    cat
  fi
}

main() {
  set -eo pipefail
  if [[ ! -p /dev/stdin && $# -eq 0 ]]; then
    elog "No stdin or arguments given"
    exit 1
  fi
  fire "$@" |
    while read -r file; do
      [[ -z $file ]] && continue
      [[ $file =~ ^#.* ]] && continue
      [[ ! -e $file ]] && continue
      pdftotext -layout "$file" -
    done
}
main "$@"
