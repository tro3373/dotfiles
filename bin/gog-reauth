#!/usr/bin/env bash

has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || error "==> No $arg command exist."; done; }
_ink() { if has ink; then ink "$@"; else cat - 1>&2; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
error() { _log red "$*" && exit 1; }

main() {
  set -euo pipefail
  hass gog fzf jq
  jq -r '.account_clients // {} | to_entries[] | "\(.key)\t\(.value)"' ~/.config/gogcli/config.json |
    fzf -1 --prompt='Account> ' --delimiter=$'\t' --with-nth=1,2 |
    while IFS=$'\t' read -r email client; do
      services=$(gog auth list | awk -F'\t' -v e="${email}" -v c="${client}" '$1==e {print $3}')
      services=
      svcs=
      if [[ -n ${services} ]]; then
        svcs="--services ${services}"
      fi
      info "==> re authenticating ${email} (${client}) with services: ${services:-none}"
      # shellcheck disable=SC2086
      gog auth add "${email}" --client="${client}" ${svcs}
    done
}
main "$@"
