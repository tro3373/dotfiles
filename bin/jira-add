#!/usr/bin/env bash

main() {
  set -eo pipefail
  if [[ ! -p /dev/stdin ]]; then
    elog "Usage: echo -e 'project\tparent\ttype\tsummary\tbody' | $0"
  fi

  cat |
    grep -vE '^project	.*body$' |
    grep -vE '^#.*$' |
    fzf --exit-0 \
      --select-1 \
      --multi \
      --tac \
      --bind 'ctrl-l:toggle-all,ctrl-g:toggle-preview,ctrl-y:execute-silent(echo {} |clip)+abort' |
    sort |
    while IFS=$'\t' read -r project parent type summary body; do
      [[ -z $project ]] && continue
      [[ $project =~ ^#.* ]] && continue
      echo -e "$body" |
        jira issue create \
          -p "${project}" \
          -t "${type}" \
          -P "${parent}" \
          -s "${summary}" \
          --no-input
    done
}
main "$@"
