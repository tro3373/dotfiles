#!/usr/bin/env bash

# preview で各 pane を末尾空行を除いた最新何行に絞るかの既定値。
# fzf 実行時は FZF_PREVIEW_LINES から 3 pane 一望になるよう上書きする。
readonly preview_pane_lines=10

# pane 状態マーカーの保存先。書込側 (hook イベント handle_event) と読取側
# (fzf list/preview) が本ファイル内でこの 1 関数を共有する (SSOT)。
# テストは TMUXS_MARKER_DIR で一時ディレクトリに上書きする。
# (旧 ~/.mo/.../tmux-pane-state.sh との二重定義は本統合で解消済み)
marker_dir() {
  printf '%s' "${TMUXS_MARKER_DIR:-${XDG_RUNTIME_DIR:-/tmp}/tmuxs}"
}

# 状態名 -> リスト行用 ANSI SGR (背景色 + 前景色)。マーカー無し(none)は非ゼロ復帰。
state_sgr() {
  case $1 in
    waiting) printf '48;2;229;175;30;38;2;0;0;0' ;;
    running) printf '48;2;121;148;120;38;2;255;255;255' ;;
    idle) printf '48;2;78;78;78;38;2;255;255;255' ;;
    *) return 1 ;;
  esac
}

# 状態名 -> preview ヘッダ帯用 SGR (太字込み)。マーカー無しは従来の青背景。
band_sgr() {
  case $1 in
    waiting) printf '1;38;2;0;0;0;48;2;229;175;30' ;;
    running) printf '1;38;2;255;255;255;48;2;121;148;120' ;;
    idle) printf '1;38;2;255;255;255;48;2;78;78;78' ;;
    *) printf '1;30;44' ;;
  esac
}

# 現存する全 pane_id を連想配列 (nameref) に集める。死んだ pane の判定に使う。
collect_alive_panes() {
  local -n _alive=$1
  local p
  while read -r p; do
    [[ -n $p ]] && _alive["$p"]=1
  done < <(tmux list-panes -a -F '#{pane_id}' 2>/dev/null)
}

# 死んだ pane (現存しない pane_id) のマーカーを削除する。
cleanup_markers() {
  local dir
  dir=$(marker_dir)
  [[ -d $dir ]] || return 0
  local -A alive=()
  collect_alive_panes alive
  local f pid
  for f in "$dir"/*; do
    [[ -e $f ]] || continue
    pid=${f##*/}
    [[ -n ${alive[$pid]:-} ]] || rm -f "$f"
  done
}

# 全セッションを 1 行ずつ列挙する。
# 1 列目 = "<session_name>" (preview / kill / switch のターゲット)。
# 最長セッション名に幅を合わせて左寄せパディングし、現在 attach 中のセッションには行末に "*" を付ける。
list_sessions() {
  local dir
  dir=$(marker_dir)

  # セッション単位の pane 総数 format は無いので、全 pane を一度に列挙して集計する。
  # 同時にマーカーから代表状態の優先度ランクを集める。
  # 優先度: waiting(3) > running(2) > idle(1) > マーカー無し(0)。
  local -A pcount=() prank=()
  local s pid st r
  while IFS=$'\t' read -r s pid; do
    [[ -n $s ]] || continue
    pcount[$s]=$((${pcount[$s]:-0} + 1))
    st=''
    [[ -f $dir/$pid ]] && st=$(<"$dir/$pid")
    case $st in
      waiting) r=3 ;;
      running) r=2 ;;
      idle) r=1 ;;
      *) r=0 ;;
    esac
    ((r > ${prank[$s]:-0})) && prank[$s]=$r
  done < <(tmux list-panes -a -F '#{session_name}'$'\t''#{pane_id}')

  # 全行を一旦読み、最長セッション名から幅を決めてから整形する。
  local -a rows=()
  local name nwin attached width=0
  while IFS=$'\t' read -r name nwin attached; do
    ((${#name} > width)) && width=${#name}
    rows+=("$name"$'\t'"$nwin"$'\t'"$attached")
  done < <(tmux list-sessions \
    -F $'#{session_name}\t#{session_windows}\t#{?session_attached,1,}')

  # 入力待ち(waiting=rank3)を含む session を上位へ。
  # waiting 群・非 waiting 群はそれぞれ元の列挙順を保つ。
  local -a ordered=() rest=()
  local row
  for row in "${rows[@]}"; do
    name=${row%%$'\t'*}
    if ((${prank[$name]:-0} == 3)); then
      ordered+=("$row")
      continue
    fi
    rest+=("$row")
  done
  ((${#rest[@]})) && ordered+=("${rest[@]}")

  local marker sname sgr
  for row in "${ordered[@]}"; do
    IFS=$'\t' read -r name nwin attached <<<"$row"
    marker=''
    [[ -n $attached ]] && marker=' *'
    case ${prank[$name]:-0} in
      3) sname=waiting ;;
      2) sname=running ;;
      1) sname=idle ;;
      *) sname='' ;;
    esac
    if sgr=$(state_sgr "$sname"); then
      printf '\033[%sm%-*s  %sw%sp%s\033[0m\n' \
        "$sgr" "$width" "$name" "$nwin" "${pcount[$name]:-0}" "$marker"
      continue
    fi
    printf '%-*s  %sw%sp%s\n' \
      "$width" "$name" "$nwin" "${pcount[$name]:-0}" "$marker"
  done
}

# ---- pane 状態の書込側 (Claude hook 統合) --------------------------------
# settings.json が pane 内で `tmuxs waiting|running|idle|remove` を呼ぶ。
# waiting が 1 つでも発生したら status bar の待ち表示 (@tmuxs_waiting) に ⏳N を
# 点灯し、全 pane の waiting が解消したら消す。読取側と marker_dir() を共有する
# (旧 ~/.mo/.../tmux-pane-state.sh の二重定義を解消)。
# best-effort のため tmux 呼び出し失敗で Claude を止めないよう常に 0 で抜ける。

# readonly waiting_color='#E5AF1E'
readonly waiting_color='#4B607F'

# 黄色帯モード。1=ON: waiting 時に status bar 全体を黄色帯で強調 (tmux.conf の
# @tmuxs_band 条件配色と連動し文字は暗色に切替わる)。0=OFF: status-left の
# ⏳N インジケータのみ。
readonly band_enabled=1

# 現存する pane のうち waiting マーカーを持つ数を数える。
# 死んだ pane のマーカーは無視する (誤って waiting 扱いしない)。
count_waiting() {
  local dir n=0
  dir=$(marker_dir)
  if [[ -d $dir ]]; then
    local -A alive=()
    collect_alive_panes alive
    local f pid
    for f in "$dir"/*; do
      [[ -e $f ]] || continue
      pid=${f##*/}
      [[ -n ${alive[$pid]:-} ]] || continue
      [[ $(<"$f") == waiting ]] && n=$((n + 1))
    done
  fi
  printf '%s' "$n"
}

# 黄色帯 ON: 現在の status-style を退避してから 黄/黒 へ直接上書きし、フラグ @tmuxs_band を立てる。
# status-style は style option で format 非展開のため tmux.conf の #{?...} では制御できず直接 set する。
# 退避済み判定は番兵 @tmuxs_band の有無で行い、二重上書きで黄色を「通常」と誤退避しないようにする。
# (conf 未リロードでも自己完結で復元できる。通常配色を hook にハードコードしない)
# 注意: 複数 pane がほぼ同時に band 突入すると show->set 非アトミックで後発が黄色を誤退避する
# レースがあるが、低頻度かつ best-effort のため未防御。
# status-left/right は文字列 option なので @tmuxs_band 条件で文字色が追従する。
band_on() {
  [[ $(tmux show -gv @tmuxs_band 2>/dev/null) == 1 ]] ||
    tmux set -g @tmuxs_status_saved "$(tmux show -gv status-style)"
  tmux set -g @tmuxs_band 1
  # 末尾に default を付けると tmux style 構文で bg/fg が端末デフォルトへリセットされ
  # 黄色帯が一切描画されない。色のみ指定する (status-style 基底に余分な属性は元々無い)。
  tmux set -g status-style "bg=${waiting_color},fg=#000000"
}

# 黄色帯 OFF: band 中なら退避値から status-style を復元し、番兵・退避値を unset する。
band_off() {
  [[ $(tmux show -gv @tmuxs_band 2>/dev/null) == 1 ]] || return 0
  tmux set -g status-style "$(tmux show -gv @tmuxs_status_saved)"
  tmux set -gu @tmuxs_status_saved
  tmux set -gu @tmuxs_band
}

# 待ち表示枠 (@tmuxs_waiting) と黄色帯を更新する。
# 入力待ち pane があれば status-left の ⏳N を点灯し、band_enabled=1 なら黄色帯も点灯。
# 無ければ消灯。同時 waiting でカウントが一時的にずれても次イベントで上書き整合する。
update_indicator() {
  local n
  n=$(count_waiting)
  if ((n > 0)); then
    # 黄色帯 ON 時は帯の上で読めるよう ⏳ を暗色、OFF 時は通常背景で映える黄色。
    local icon_color="$waiting_color"
    ((band_enabled)) && icon_color='#000000'
    tmux set -g @tmuxs_waiting "#[fg=${icon_color},bold]⏳${n} #[default]"
    ((band_enabled)) && band_on
    return
  fi
  tmux set -gu @tmuxs_waiting
  band_off
}

# state に応じて pane マーカーを更新する。remove は削除し、それ以外は内容を書き込む。
write_marker() {
  local state=$1 dir=$2 file=$3
  if [[ $state == remove ]]; then
    rm -f "$file"
    return
  fi
  mkdir -p "$dir"
  printf '%s' "$state" >"$file"
}

# hook イベント本体。tmux 外 (TMUX_PANE / TMUX 未設定) では何もせず戻る。
# best-effort のため set -e を効かせず、呼び出し元が exit 0 する。
handle_event() {
  [[ -n ${TMUX_PANE:-} && -n ${TMUX:-} ]] || return 0

  local state=$1 dir file old=''
  dir=$(marker_dir)
  file="${dir}/${TMUX_PANE}"
  [[ -f $file ]] && old=$(<"$file")

  write_marker "$state" "$dir" "$file"

  # 待ち表示の再計算は waiting が絡む遷移時のみ (running 連発時の tmux IPC 抑制)。
  if [[ $old == waiting || $state == waiting ]]; then
    update_indicator
  fi
  return 0
}

# ---- 手動確認ツール (`tmuxs __test-event`) -------------------------------
# 現在の pane を指定状態にし (本物のイベント処理 handle_event をそのまま呼ぶ)、
# 結果のマーカー/tmux option を表示する。状態設定ロジックは複製せず本体関数を再利用。
#   tmuxs __test-event waiting|running|idle|remove  # 状態を設定し結果表示
#   tmuxs __test-event status                       # 現状表示のみ (副作用なし)
#   tmuxs __test-event                              # fzf で選択
# tmux 外 (TMUX / TMUX_PANE 未設定) はエラーで抜ける。

# 現在の pane の状態 (マーカー内容・関連 tmux option・全 marker) を表示する。
show_state() {
  local dir file
  dir=$(marker_dir)
  file="${dir}/${TMUX_PANE}"

  printf '== pane %s state ==\n' "${TMUX_PANE}"
  printf 'marker 内容    : %s\n' "$([[ -f $file ]] && cat "$file" || printf '(none)')"
  printf '@tmuxs_waiting : %s\n' "$(tmux show -gv @tmuxs_waiting 2>/dev/null || true)"
  printf '@tmuxs_band    : %s\n' "$(tmux show -gv @tmuxs_band 2>/dev/null || true)"
  printf 'status-style   : %s\n' "$(tmux show -gv status-style 2>/dev/null || true)"
  printf '全 marker リスト (%s):\n' "${dir}"
  if [[ ! -d $dir ]]; then
    printf '  (dir なし)\n'
    return
  fi
  local f found=0
  for f in "${dir}"/*; do
    [[ -e $f ]] || break
    found=1
    printf '  %s = %s\n' "${f##*/}" "$(cat "$f")"
  done
  ((found)) || printf '  (empty)\n'
}

test_event() {
  set -euo pipefail
  [[ -n ${TMUX_PANE:-} && -n ${TMUX:-} ]] ||
    {
      printf 'error: tmux 外では実行できない (TMUX / TMUX_PANE 未設定)\n' >&2
      exit 1
    }

  local status=${1:-}
  [[ -n $status ]] || status=$(printf '%s\n' waiting running idle remove status |
    fzf --prompt='tmux-pane-state > ' --height=40% --reverse) ||
    {
      printf 'error: cancelled\n' >&2
      exit 1
    }

  case "${status}" in
    waiting | running | idle | remove) handle_event "${status}" ;;
    status) ;; # 現状表示のみ (副作用なし)
    *)
      printf 'error: unknown status: %s (waiting|running|idle|remove|status)\n' \
        "${status}" >&2
      exit 1
      ;;
  esac

  show_state
}

main() {
  case "${1:-}" in
    waiting | running | idle | remove)
      # Claude hook エントリ。best-effort のため tmux 失敗でも常に 0 で抜ける。
      handle_event "$1"
      exit 0
      ;;
    __test-event)
      shift
      test_event "$@"
      exit
      ;;
  esac

  set -euo pipefail

  case "${1:-}" in
    __kill)
      shift
      # target ("<session>:<window_index>") が属するセッションを安全に kill する。
      # 対象が現在 client のセッションなら、別セッションへ switch してから kill し、
      # 端末が detach されないようにする。
      local target=$1
      local session=${target%:*}
      local current
      current=$(tmux display-message -p '#{session_name}')
      if [[ $session == "$current" ]]; then
        local other
        other=$(tmux list-sessions -F '#{session_name}' |
          grep -vFx "$session" | head -n1 || true)
        if [[ -n $other ]]; then
          tmux switch-client -t "$other"
        fi
      fi
      tmux kill-session -t "$session"
      ;;
    __list) list_sessions ;;
    __cleanup) cleanup_markers ;;
    __new)
      # 新しいセッションを detached で作成し (名前は tmux 自動採番)、
      # 作成したセッションへ switch-client する。呼び出し元 fzf 側で accept して抜ける。
      local name
      name=$(tmux new-session -dP -F '#{session_name}')
      tmux switch-client -t "$name"
      ;;
    __switch)
      shift
      # 選択セッションへ switch する。waiting pane があればそこへ focus を移して
      # attach し、無ければ focus を動かさず last-active pane を維持する。
      # 複数 waiting があれば列挙順 (window->pane index) で最初を採用。
      local target=$1 session mdir
      session=${target%:*}
      mdir=$(marker_dir)

      local waitwidx='' waitpid='' widx pid
      while IFS=$'\t' read -r widx pid; do
        [[ -n $pid ]] || continue
        [[ -f $mdir/$pid && $(<"$mdir/$pid") == waiting ]] || continue
        waitwidx=$widx
        waitpid=$pid
        break
      done < <(tmux list-panes -s -t "$session" \
        -F $'#{window_index}\t#{pane_id}')

      tmux switch-client -t "$session"
      [[ -n $waitpid ]] || return 0
      tmux select-window -t "$session:$waitwidx"
      tmux select-pane -t "$waitpid"
      ;;
    __preview)
      shift
      # 選択行 ("<session_name>") が属するセッションの全 window×pane を縦に積んで表示する。
      # ヘッダは tmux のタブ選択色(青背景・黒太字)で横幅いっぱいに塗る (各 window の active pane に *)。
      # 末尾空行を除いた最新 cap 行に各 pane を絞る。1 画面に最大 3 pane を収めるが、
      # pane 数が 3 未満ならその数で割り、少ない pane のときに高さを余らせない。
      local target=$1 session cols cap divisor mdir
      session=${target%:*}
      cols=${FZF_PREVIEW_COLUMNS:-80}
      mdir=$(marker_dir)

      local -a panes
      mapfile -t panes < <(tmux list-panes -s -t "$session" \
        -F $'#{pane_active}\t#{window_index}\t#{pane_index}\t#{window_name}\t#{pane_current_command}\t#{pane_id}\t#{pane_current_path}')

      divisor=${#panes[@]}
      ((divisor > 3)) && divisor=3
      ((divisor < 1)) && divisor=1
      cap=$preview_pane_lines
      [[ -n ${FZF_PREVIEW_LINES:-} ]] && cap=$((FZF_PREVIEW_LINES / divisor - 2))
      ((cap < 3)) && cap=3

      local line active widx pidx wname cmd pid path dir mark st band
      for line in "${panes[@]}"; do
        IFS=$'\t' read -r active widx pidx wname cmd pid path <<<"$line"
        mark=''
        [[ $active == 1 ]] && mark=' *'
        dir=${path##*/}
        [[ -z $dir ]] && dir=/
        st=''
        [[ -f $mdir/$pid ]] && st=$(<"$mdir/$pid")
        band=$(band_sgr "$st")
        printf '\033[%sm%-*s\033[0m\n' "$band" "$cols" \
          "$session: win=$wname / $widx.$pidx $cmd [$dir]$mark"
        tmux capture-pane -ep -t "$pid" 2>/dev/null |
          awk -v n="$cap" '
            { buf[NR] = $0; if ($0 ~ /[^[:space:]]/) last = NR }
            END {
              start = last - n + 1
              if (start < 1) start = 1
              for (i = start; i <= last; i++) print buf[i]
            }'
        printf '\n'
      done
      ;;
    __rename)
      shift
      # 選択中セッションの名前を対話的に変更する。
      # fzf の execute() は端末を明け渡すので read でプロンプトを出せる。
      # fzf 実行中はカーソル非表示なので明示再表示し、前回プロンプトの残骸を
      # 消すため画面をクリアする。read -e で readline 行編集 (inputrc が vi なら
      # vi バインド)、-i で現在名をプリフィルする。
      local target=$1
      local session=${target%:*}
      local new
      printf '\033[2J\033[3J\033[H\033[?25h'
      read -er -p "Rename to: " -i "$session" new || true
      [[ -n $new && $new != "$session" ]] && tmux rename-session -t "$session" "$new"
      ;;
    *)
      local self
      self=$(realpath "$0")
      cleanup_markers
      list_sessions |
        fzf --reverse --no-input --ansi \
          --preview "$self __preview {1}" \
          --preview-window right:80% \
          --bind 'q:abort' \
          --bind 'j:down,k:up' \
          --bind 'J:preview-down,K:preview-up' \
          --bind "enter:execute($self __switch {1})+accept" \
          --bind "n:execute($self __new)+accept" \
          --bind "r:execute($self __rename {1})+reload($self __list)" \
          --bind "x:execute-silent($self __kill {1})+reload($self __list)"
      ;;
  esac
}

if [[ ${BASH_SOURCE[0]} == "$0" ]]; then
  main "$@"
fi
