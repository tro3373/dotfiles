#!/usr/bin/env bash

find_root_dirs=("$HOME"/src)
find_entries() {
  # git repository を探す
  for d in "${find_root_dirs[@]}"; do
    [[ -d $d ]] || continue
    find "$d/" -maxdepth 4 -type d -name '.git' -print0 2>/dev/null |
      sed -z 's|/.git$||' 2>/dev/null
  done
}

sources() {
  {
    echo "$HOME/.dot"
    find_entries
    ghq list --full-path
  } 2>/dev/null
}

main() {
  set -eo pipefail
  sources |
    while IFS= read -r dir; do
      [[ ! -d $dir ]] && continue
      printf '%s\t%s\n' "$(stat -c %Y "$dir" 2>/dev/null || echo 0)" "$dir"
    done |
    sort -n |
    cut -f2-
}
main "$@"
