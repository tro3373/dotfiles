#!/usr/bin/env -S bash -e

current_dir=$(pwd) && readonly current_dir
command_name=$(basename "$0") && readonly command_name
readonly depends=(bunx markitdown)
dst_dir="$current_dir"
args=()

add_args() { args+=("$@"); }
has() { command -v "${1}" >&/dev/null; }
hass() { for arg in "$@"; do has "$arg" || error "==> No $arg command exist."; done; }
_ink() { cat - | if has ink; then ink "$@"; else cat -; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
error() { _log red "$*" && exit 1; }

usage() {
  cat <<EOF

Save web page as markdown file.

  Usage:
      $command_name [option]
    Options
      -h|--help : Show this usage
      -d|--dst  : Destination directory (default: current directory)

EOF
}

sanitize() {
  [[ -t 0 ]] && error "==> No string provided."
  sed -e 's/[\/\:*?"<>|!]/-/g' -e 's/--*/-/g' -e 's/^-//' -e 's/-$//'
}

get_title_from_md() {
  f="$*"
  [[ ! -e $f ]] && error "==> No such file: $f"
  title=$(grep '^#' "$tmp_md" | head -1 | sed -e 's/^[# \t]\+//' -e 's/ /_/g')
  if [[ -z $title ]]; then
    title=$(basename "$tmp_md" .md)
  fi
  echo "$title" | sanitize
}

download_to_markdown() {
  timestamp=$(date +%Y%m%d-%H%M%S)
  tmp_md=/tmp/"$timestamp".md
  bunx @mizchi/readability "$url" -o "$tmp_md"
  if [[ ! -s $tmp_md ]]; then
    markitdown "$url" -o "$tmp_md"
  fi
  echo "$tmp_md"
}

handle_url() {
  tmp_md=$(download_to_markdown)
  title=$(get_title_from_md "$tmp_md")
  timestamp=$(date +%Y%m%d-%H%M%S)
  dst="$dst_dir/${timestamp}_$title.md"
  while [[ -e $dst ]]; do
    timestamp=$(date +%Y%m%d-%H%M%S)
    dst="$dst_dir/${timestamp}_$title.md"
  done
  mv "$tmp_md" "$dst"
  info "==> Saved: $dst"
}

fire() {
  {
    if [[ -p /dev/stdin ]]; then
      cat -
    fi
    if [[ $# -ne 0 ]]; then
      echo "$@"
    fi
  } | tr " " "\n"
}

initialize() {
  while true; do
    [[ -z $1 ]] && break
    case "$1" in
      -h | --help) usage && exit 0 ;;
      -d | --dst) shift && dst_dir=$1 ;;
      *) add_args "$1" ;;
    esac
    shift
  done
  check "${args[@]}"
  if [[ ! -d $dst_dir ]]; then
    mkdir -p "$dst_dir"
  fi
  set -euo pipefail
}

check() {
  hass "${depends[@]}"
  if [[ ! -p /dev/stdin && $# -eq 0 ]]; then
    error "==> No URL provided."
  fi
}

main() {
  initialize "$@"
  fire "${args[@]}" |
    while read -r url; do
      [[ -z $url ]] && continue
      [[ $url =~ ^#.* ]] && continue
      handle_url
    done
}
main "$@"
