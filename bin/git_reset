#!/usr/bin/env bash

has() { command -v "${1}" >&/dev/null; }
hass() { for _arg in "$@"; do has "$_arg" || die "==> No $_arg command exist."; done; }
_ink() { if has ink; then ink "$@"; else cat - 1>&2; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
die() { _log red "$*" && exit 1; }
main() {
  set -eo pipefail
  git_root=$(git rev-parse --show-toplevel 2>/dev/null || :)
  [[ -z $git_root ]] && die "==> Not git repository"
  marker="$git_root/.git/.git-reset-marker"
  if [[ $1 == -r ]]; then
    if [[ ! -e $marker ]]; then
      die "==> No reset marker found. Cannot reset."
    fi
    hash="$(cat <"$marker")"
    git reset "$hash"
    info "==> Restored by $hash"
    return
  fi
  git rev-parse HEAD >"$marker"
  git reset HEAD^
  warn "==> Executed: git reset HEAD^"
  warn "    Marker: $marker"
  warn "    Hash: $(cat <"$marker")"
}
main "$@"
