#!/usr/bin/env bash

command_name=$(basename "$0") && readonly command_name
has() { command -v "${1}" >&/dev/null; }
hass() { for _arg in "$@"; do has "$_arg" || die "==> No $_arg command exist."; done; }
_ink() { if has ink; then ink "$@"; else cat - 1>&2; fi; }
# shellcheck disable=SC2145
_log() { echo "$(date +"%Y-%m-%d %H:%M:%S") ${@:2}" | _ink "$1"; }
log() { _log white "$*"; }
info() { _log cyan "$*"; }
warn() { _log yellow "$*"; }
die() { _log red "$*" && exit 1; }
main() {
  set -eo pipefail
  git_root=$(git rev-parse --show-toplevel 2>/dev/null || :)
  [[ -z $git_root ]] && die "==> Not git repository"
  repo_dir_name=${git_root/\//}
  repo_dir_name=${repo_dir_name//\//-}
  config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/$command_name"
  [[ ! -d $config_dir ]] && mkdir -p "$config_dir"
  marker="$config_dir/$repo_dir_name"
  if [[ $1 == -r ]]; then
    if [[ ! -e $marker ]]; then
      die "==> No reset marker found. Cannot reset."
    fi
    hash="$(head -1 "$marker")"
    git reset "$hash"
    info "==> Restored: git reset $hash"
    info "    Marker: $marker"
    info "    Hash: $(cat <"$marker")"
    # rm -v "$marker"
    return
  fi
  if [[ $1 == -v ]]; then
    if [[ ! -e $marker ]]; then
      die "==> No reset marker found. Cannot reset."
    fi
    echo "$marker" | v
    return
  fi
  git rev-parse HEAD >"$marker"
  git log -1 >>"$marker"
  git reset HEAD^
  warn "==> Executed: git reset HEAD^"
  warn "    Marker: $marker"
  warn "    Hash: $(cat <"$marker")"
}
main "$@"
