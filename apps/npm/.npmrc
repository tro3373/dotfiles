# ref: https://zenn.dev/cycloud_blog/articles/5ce66daf4bd0cb

prefix=~/.npm-global
# engines 不一致を警告で流さず、インストールを失敗. Node/npmのバージョン差で起きる再現しづらい不具合を減らす
engine-strict=true
# 依存パッケージの preinstall / install / postinstall を自動実行させない. インストール時の任意コード実行リスクを下げる
ignore-scripts=true
# npm install 実行時の脆弱性監査を常時有効にする. 既知の脆弱な依存を早めに検出しやすくする
audit=true
# 公開直後のバージョンをすぐには取り込まないための設定. 不正なバージョンを公開直後に取り込んでしまう確率を下げる
min-release-age=1

# # 新規追加する依存を ^1.2.3 ではなく 1.2.3 で保存する設定
# save-exact=true
# # npm audit をどの深刻度で失敗させるか
# audit-level=high
# # peer dependency の衝突を警告で流さず、インストールを失敗
# strict-peer-deps=true
# # git参照依存の利用範囲を制限
# allow-git=root
