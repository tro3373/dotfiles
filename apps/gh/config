#!/usr/bin/env bash

install_common() {
  platform=$(get_platform)
  arch=$(get_arch)
  # https://github.com/cli/cli/releases/download/v2.92.0/gh_2.92.0_linux_arm64.tar.gz
  dl_gh_release cli/cli latest "*${platform}_${arch}.tar.gz"
  exe 'tar -xzf gh*.tar.gz'
  exe 'sudo cp gh*/bin/gh /usr/local/bin/'
}
