install_arch() {
  # NOTE: install latest `gh` command via `gh` command.
  # - yay install gh command to /usr/bin
  # - dl_gh_release install gh command to /usr/local/bin
  # - /usr/local/bin is higher priority than /usr/bin, so dl_gh_release is used to install latest version.
  def_install github-cli
  install_common
}
