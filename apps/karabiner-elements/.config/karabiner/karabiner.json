{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "left_control to left_command (Ctrl+H fix included)",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.googlecode\\.iterm2",
                                            "^com\\.github\\.wez\\.wezterm"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "description": "ブラウザ等で化けたCtrl+H(Cmd+H)を削除に変換",
                                "from": {
                                    "key_code": "h",
                                    "modifiers": {
                                        "mandatory": ["command"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "delete_or_backspace" }],
                                "type": "basic"
                            },
                            {
                                "description": "WezTerm等ではCtrl+HをそのままBackspaceとして通す",
                                "from": {
                                    "key_code": "h",
                                    "modifiers": {
                                        "mandatory": ["control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "delete_or_backspace" }],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.googlecode\\.iterm2",
                                            "^com\\.github\\.wez\\.wezterm"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "description": "それ以外のControlをCommandに変換(WezTerm等を除く)",
                                "from": {
                                    "key_code": "left_control",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_command" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Paste(Shift+Insert)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "insert",
                                    "modifiers": {
                                        "mandatory": ["shift"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "v",
                                        "modifiers": ["left_command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "option-EでFinder(Downloads)を開く",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "e",
                                    "modifiers": {
                                        "mandatory": ["left_option"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "shell_command": "open ~/Downloads" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "コマンドキーを単体で押したときに、英数・かなキーを送信する。（左コマンドキーは英数、右コマンドキーはかな） (rev 3)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "left_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "parameters": { "basic.to_if_held_down_threshold_milliseconds": 100 },
                                "to": [
                                    {
                                        "key_code": "left_command",
                                        "lazy": true
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "japanese_eisuu" }],
                                "to_if_held_down": [{ "key_code": "left_command" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "right_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "parameters": { "basic.to_if_held_down_threshold_milliseconds": 100 },
                                "to": [
                                    {
                                        "key_code": "right_command",
                                        "lazy": true
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "japanese_kana" }],
                                "to_if_held_down": [{ "key_code": "right_command" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
