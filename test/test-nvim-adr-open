#!/usr/bin/env bash

# apps/vim/.vim/conf.d/102_funcs.vim の OpenUrlOrFilePathOnCursor が
# `ADR-<番号>` 参照を docs/adr 配下へ解決して開く挙動のテスト (実 nvim headless)。
#
# nvim は本体 (g:is_* / g:plug) 依存を持つため、最小スタブ harness.vim を先に
# source してから 102_funcs.vim を source する。隔離 git repo と note ファイルを
# 用意し、driver.vim が関数を呼んで「新規タブで開かれた対象」を probe に書き出す。
#
# 検証対象 (要件):
#   * 専用ファイル : docs/adr/0007-*.md 存在      => その .md を開く
#   * index 退避   : 0007 無し・0000-index.md 有り => index を開く
#   * dir 退避     : md 全く無し・docs/adr 有り     => docs/adr ディレクトリを開く
#   * error        : docs/adr 自体が無い            => 新規タブ無し (ERROR)
#   * 番号正規化   : ADR-7 / ADR-007 も 0007-*.md にマッチ
#
#   test/test-nvim-adr-open   # 全テスト実行

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
funcs=$(cd "${script_dir}/../apps/vim/.vim/conf.d" && pwd)/102_funcs.vim

tmproot=$(mktemp -d)
trap 'rm -rf "${tmproot}"' EXIT
probe="${tmproot}/probe.txt"

pass=0
fail=0

# desc / expected / actual を比較し、pass・fail カウンタを更新する。
check() {
  local desc="$1" expected="$2" actual="$3"
  if [[ ${expected} != "${actual}" ]]; then
    fail=$((fail + 1))
    printf 'FAIL - %s\n  expected: %q\n  actual:   %q\n' "${desc}" "${expected}" "${actual}"
    return
  fi
  pass=$((pass + 1))
  printf 'ok   - %s\n' "${desc}"
}

# g:is_* / g:plug を最小スタブする harness と、関数を駆動する driver を書き出す。
harness="${tmproot}/harness.vim"
cat >"${harness}" <<'VIM'
let g:is_wsl = 0
let g:is_orb = 0
let g:is_windows = 0
let g:is_mac = 0
let g:is_linux = 1
let g:winclip = ''
let g:plug = {}
function! g:plug.is_installed(name) abort
  return 0
endfunction
VIM

driver="${tmproot}/driver.vim"
cat >"${driver}" <<'VIM'
execute 'source ' . $adr_harness
execute 'source ' . $adr_funcs
execute 'edit ' . fnameescape($adr_note)
let g:before = tabpagenr('$')
silent! call OpenUrlOrFilePathOnCursor()
let g:after = tabpagenr('$')
" 1 行目: 最後に開かれたタブの対象 (無ければ ERROR) / 2 行目: 増えたタブ数
let g:opened = g:after > g:before ? fnamemodify(bufname(winbufnr(0)), ':p') : 'ERROR'
call writefile([g:opened, string(g:after - g:before)], $adr_out)
qa!
VIM

# 隔離 git repo を作る。$1=repo 名。docs/adr の中身は呼び出し側が用意する。
new_repo() {
  local repo="${tmproot}/$1"
  rm -rf "${repo}"
  mkdir -p "${repo}"
  git -C "${repo}" init -q
  printf '%s' "${repo}"
}

# repo 内 note.md に ADR 参照行を置いて関数を駆動し、probe に結果を残す。
# probe 1 行目=開かれた絶対パス or ERROR、2 行目=増えたタブ数。
_drive() {
  local repo="$1" line="$2"
  printf '%s\n' "${line}" >"${repo}/note.md"
  : >"${probe}"
  adr_harness="${harness}" adr_funcs="${funcs}" \
    adr_note="${repo}/note.md" adr_out="${probe}" \
    nvim --headless --clean -S "${driver}" >/dev/null 2>&1
}

# 開かれた対象 (末尾 / は除去) を返す。
run_case() {
  _drive "$1" "$2"
  local r
  r=$(sed -n 1p "${probe}" 2>/dev/null)
  printf '%s' "${r%/}"
}

# 増えたタブ数を返す。
run_tabs() {
  _drive "$1" "$2"
  sed -n 2p "${probe}" 2>/dev/null
}

main() {
  set -euo pipefail
  local repo

  # 1. 専用ファイルが存在 => その .md を開く
  repo=$(new_repo file_found)
  mkdir -p "${repo}/docs/adr"
  touch "${repo}/docs/adr/0007-foo.md" "${repo}/docs/adr/0000-index.md"
  check 'ADR-0007 で 0007-*.md を開く' \
    "${repo}/docs/adr/0007-foo.md" "$(run_case "${repo}" 'see ADR-0007 for details')"

  # 2. 専用ファイル無し・index 有り => index を開く
  repo=$(new_repo index_fallback)
  mkdir -p "${repo}/docs/adr"
  touch "${repo}/docs/adr/0000-index.md"
  check 'ADR-0007 該当無しで 0000-index.md を開く' \
    "${repo}/docs/adr/0000-index.md" "$(run_case "${repo}" 'ADR-0007 は未作成')"

  # 3. md 全く無し・docs/adr 有り => ディレクトリを開く
  repo=$(new_repo dir_fallback)
  mkdir -p "${repo}/docs/adr"
  check 'ADR-0007 file/index 無しで docs/adr を開く' \
    "${repo}/docs/adr" "$(run_case "${repo}" 'ADR-0007 参照')"

  # 4. docs/adr 自体が無い => 新規タブ無し (ERROR)
  repo=$(new_repo no_dir)
  check 'docs/adr 無しでエラー (新規タブ無し)' \
    'ERROR' "$(run_case "${repo}" 'ADR-0007 参照')"

  # 5. 番号正規化: ADR-7 も 0007-*.md にマッチ
  repo=$(new_repo norm_1digit)
  mkdir -p "${repo}/docs/adr"
  touch "${repo}/docs/adr/0007-foo.md"
  check 'ADR-7 が 0007-*.md にマッチ' \
    "${repo}/docs/adr/0007-foo.md" "$(run_case "${repo}" 'ADR-7 参照')"

  # 6. 番号正規化: ADR-007 も 0007-*.md にマッチ
  repo=$(new_repo norm_3digit)
  mkdir -p "${repo}/docs/adr"
  touch "${repo}/docs/adr/0007-foo.md"
  check 'ADR-007 が 0007-*.md にマッチ' \
    "${repo}/docs/adr/0007-foo.md" "$(run_case "${repo}" 'ADR-007 参照')"

  # 7. Markdownリンク行はパス側で 1 回だけ開く (ADR 二重オープン防止)
  repo=$(new_repo md_link_no_dup)
  mkdir -p "${repo}/docs/adr"
  touch "${repo}/docs/adr/0007-foo.md"
  check 'リンク [ADR-0007](docs/adr/0007-foo.md) は 1 タブのみ' \
    '1' "$(run_tabs "${repo}" '- [ADR-0007](docs/adr/0007-foo.md)')"

  # 8. 1 行に複数 ADR => それぞれ開く
  repo=$(new_repo multi_adr)
  mkdir -p "${repo}/docs/adr"
  touch "${repo}/docs/adr/0001-a.md" "${repo}/docs/adr/0002-b.md"
  check 'ADR-0001 と ADR-0002 で 2 タブ' \
    '2' "$(run_tabs "${repo}" 'ADR-0001 を ADR-0002 で置換')"

  # 9. 同一番号の重複は 1 回だけ開く
  repo=$(new_repo dup_adr)
  mkdir -p "${repo}/docs/adr"
  touch "${repo}/docs/adr/0007-foo.md"
  check 'ADR-0007 が 2 回でも 1 タブ' \
    '1' "$(run_tabs "${repo}" 'ADR-0007 と ADR-0007 の重複')"

  echo
  echo "pass=${pass} fail=${fail}"
  [[ ${fail} -eq 0 ]]
}

main "$@"
